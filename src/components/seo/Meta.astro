---
import type { Lang } from '../../i18n/index';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  lang: Lang;
  canonicalUrl?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  lang,
  canonicalUrl = Astro.url.href,
} = Astro.props;

const allLangs: Lang[] = ['en', 'ua', 'pt', 'es'];

function getHrefLang(l: Lang): string {
  const base = Astro.url.origin;
  return `${base}/${l}/`;
}
---

<!-- Primary meta -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Hreflang for all 4 locales -->
{allLangs.map((l) => (
  <link rel="alternate" hreflang={l} href={getHrefLang(l)} />
))}
<link rel="alternate" hreflang="x-default" href={getHrefLang('ua')} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={lang === 'en' ? 'en_US' : lang === 'ua' ? 'uk_UA' : lang === 'pt' ? 'pt_PT' : 'es_ES'} />

<!-- Twitter / X Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@0xGrek" />
<meta name="twitter:creator" content="@0xGrek" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
