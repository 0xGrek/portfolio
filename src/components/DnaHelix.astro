---
// DnaHelix — generative double-helix background
// Pure Canvas 2D, fixed viewport layer, always visible on scroll
// Architecture copied from WireframeSphere — CSS <style> block, z-index: 0
---

<div
  id="dna-helix-container"
  aria-hidden="true"
  class="pointer-events-none select-none"
>
  <canvas id="dna-helix-canvas" style="z-index: -10"></canvas>
</div>

<script is:inline>
(function () {
  'use strict';

  var reducedMotion =
    typeof window !== 'undefined' &&
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  var container = document.getElementById('dna-helix-container');
  var canvas = document.getElementById('dna-helix-canvas');
  if (!container || !canvas) return;

  var ctx = canvas.getContext('2d');
  if (!ctx) return;

  /* ─── DPR & sizing ─── */
  var DPR = Math.min(window.devicePixelRatio || 1, 2);
  var VW = window.innerWidth;
  var VH = window.innerHeight;
  var isMobile = VW < 768;

  /* ─── Resize canvas + container ─── */
  function resize() {
    VW = window.innerWidth;
    VH = window.innerHeight;
    isMobile = VW < 768;

    canvas.width  = VW * DPR;
    canvas.height = VH * DPR;
    canvas.style.width  = VW + 'px';
    canvas.style.height = VH + 'px';
    ctx.setTransform(DPR, 0, 0, DPR, 0, 0);

    /* inset:0 in CSS already handles sizing — no need for inline width/height
       which can interfere with the fixed positioning */
    buildHelix();
  }

  /* ─── Accent color ─── */
  var LANG_COLORS = {
    ua: '0, 122, 255',
    en: '99, 102, 241',
    pt: '20, 184, 166',
    es: '245, 158, 11',
  };

  function getAccentRgb() {
    var raw = getComputedStyle(document.documentElement).getPropertyValue('--accent-rgb').trim();
    if (raw) return raw;
    var lang = (document.documentElement.getAttribute('data-lang') || 'en').toLowerCase();
    return LANG_COLORS[lang] || LANG_COLORS['en'];
  }

  var accentRgb = getAccentRgb();
  var purpleRgb = '163, 113, 247';

  var langObserver = new MutationObserver(function () {
    accentRgb = getAccentRgb();
  });
  langObserver.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-lang', 'lang'],
  });

  /* ─── Scroll state ─── */
  var currentScroll = 0;

  window.addEventListener('scroll', function () {
    currentScroll = window.scrollY;
  }, { passive: true });

  /* Lenis compat — check if lenis exposes scroll */
  var lenisCheckInterval = setInterval(function () {
    var lenis = window.__lenis || window.lenis;
    if (lenis && lenis.on) {
      lenis.on('scroll', function (e) {
        currentScroll = (e && (e.scroll || e.animatedScroll)) || window.scrollY;
      });
      clearInterval(lenisCheckInterval);
    }
  }, 200);

  /* ─── Mouse ─── */
  var mouse = { x: VW * 0.5, y: VH * 0.5 };
  if (!isMobile) {
    document.addEventListener('mousemove', function (e) {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    }, { passive: true });
  }

  /* ══════════════════════════════════════════════
     DNA HELIX PARAMETERS
  ══════════════════════════════════════════════ */

  /* Viewport-filling geometry:
     HELIX_HEIGHT = VH * 1.2 — helix taller than screen so it always fills */
  var STRAND_COUNT  = 0;
  var BRIDGE_EVERY  = 0;
  var HELIX_RADIUS  = 0;
  var HELIX_HEIGHT  = 0;
  var TWIST_TURNS   = 5;
  var OFFSET_X      = 0;

  /* Animation */
  var AUTO_ROT_SPEED  = 0.00018; /* radians / ms */
  var SCROLL_ROT_MULT = 0.0008;  /* scroll parallax factor */

  /* ─── Helix particles ─── */
  var strand1 = [];
  var strand2 = [];
  var bridges = [];

  function buildHelix() {
    STRAND_COUNT  = isMobile ? 180 : 400;
    BRIDGE_EVERY  = isMobile ? 6   : 4;
    HELIX_RADIUS  = isMobile ? 70  : 110;
    HELIX_HEIGHT  = VH * 1.3;  /* taller than viewport → always fills screen */
    OFFSET_X      = isMobile ? 0.5 : 0.58; /* slightly right of center */

    strand1 = [];
    strand2 = [];
    bridges = [];

    for (var i = 0; i < STRAND_COUNT; i++) {
      var t = i / (STRAND_COUNT - 1);
      var angle = t * Math.PI * 2 * TWIST_TURNS;

      var ux  = Math.cos(angle);
      var uz  = Math.sin(angle);
      var y   = (t - 0.5) * HELIX_HEIGHT; /* -HELIX_HEIGHT/2 to +HELIX_HEIGHT/2 */

      strand1.push({ ux: ux, uz: uz, y: y, idx: i });

      var ux2 = Math.cos(angle + Math.PI);
      var uz2 = Math.sin(angle + Math.PI);
      strand2.push({ ux: ux2, uz: uz2, y: y, idx: i + STRAND_COUNT });

      if (i % BRIDGE_EVERY === 0) bridges.push(i);
    }
  }

  /* ─── 3D rotation ─── */
  var autoRotY = 0;  /* accumulates each frame */
  var rotX     = 0.15; /* fixed slight X tilt for depth */

  /* ─── Smooth noise for organic motion ─── */
  var noiseTime = 0;
  var NOISE_SPEED = 0.00022;

  function smoothNoise(x, t) {
    return (
      Math.sin(x * 0.8 + t * 0.7) * 0.35 +
      Math.sin(x * 1.3 - t * 0.5) * 0.25 +
      Math.sin(x * 2.1 + t * 1.1) * 0.15 +
      Math.sin(x * 3.7 - t * 0.3) * 0.08
    );
  }

  /* ─── Project 3D → 2D ─── */
  function project(ux, uz, y, rotY) {
    var wx = ux * HELIX_RADIUS;
    var wz = uz * HELIX_RADIUS;
    var wy = y;

    /* Rotate Y (spin) */
    var cosY = Math.cos(rotY);
    var sinY = Math.sin(rotY);
    var rx = wx * cosY + wz * sinY;
    var rz = -wx * sinY + wz * cosY;

    /* Rotate X (tilt) */
    var cosX = Math.cos(rotX);
    var sinX = Math.sin(rotX);
    var ry  = wy * cosX - rz * sinX;
    var rz2 = wy * sinX + rz * cosX;

    var fov   = 700;
    var depth = rz2 + fov;
    var scale = fov / (depth > 1 ? depth : 1);

    var clampFn = function (v, lo, hi) { return v < lo ? lo : v > hi ? hi : v; };

    return {
      x:     VW * OFFSET_X + rx * scale,
      y:     VH * 0.5 + ry * scale,
      z:     rz2,
      scale: scale,
      depth: clampFn((rz2 + fov) / (fov * 2), 0, 1),
    };
  }

  /* ─── Mouse repulsion ─── */
  function mouseForce(px, py) {
    if (isMobile) return { dx: 0, dy: 0 };
    var dx = px - mouse.x;
    var dy = py - mouse.y;
    var d  = Math.sqrt(dx * dx + dy * dy);
    var R  = 110;
    if (d < R && d > 0.1) {
      var f = (1 - d / R) * 7;
      return { dx: (dx / d) * f, dy: (dy / d) * f };
    }
    return { dx: 0, dy: 0 };
  }

  /* ══════════════════════════════════════════════
     DRAW FRAME
  ══════════════════════════════════════════════ */
  function clamp(v, lo, hi) { return v < lo ? lo : v > hi ? hi : v; }

  function draw(rotY) {
    ctx.clearRect(0, 0, VW, VH);

    var isDark = document.documentElement.classList.contains('dark');
    var oMult  = isDark ? 0.5 : 0.35;

    /* Clip margin — hide particles just outside viewport */
    var margin = VH * 0.55;

    var proj1 = [], proj2 = [];

    for (var i = 0; i < STRAND_COUNT; i++) {
      var s1 = strand1[i];
      var s2 = strand2[i];
      var nx  = smoothNoise(i * 0.15, noiseTime) * 3.0;
      var ny  = smoothNoise(i * 0.13 + 100, noiseTime) * 1.2;

      var p1 = project(s1.ux, s1.uz, s1.y + ny, rotY);
      p1.x += nx;
      proj1.push(p1);

      var p2 = project(s2.ux, s2.uz, s2.y + ny, rotY);
      p2.x += nx;
      proj2.push(p2);
    }

    /* ── Strand lines 1 ── */
    for (var i = 0; i < proj1.length - 1; i++) {
      var a = proj1[i], b = proj1[i + 1];
      if (a.y < -margin && b.y < -margin) continue;
      if (a.y > VH + margin && b.y > VH + margin) continue;
      var dAvg  = (a.depth + b.depth) * 0.5;
      var alpha = clamp(dAvg * 0.55 + 0.08, 0.05, 0.45) * oMult;
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = 'rgba(' + accentRgb + ',' + alpha + ')';
      ctx.lineWidth = 0.9;
      ctx.stroke();
    }

    /* ── Strand lines 2 ── */
    for (var i = 0; i < proj2.length - 1; i++) {
      var a = proj2[i], b = proj2[i + 1];
      if (a.y < -margin && b.y < -margin) continue;
      if (a.y > VH + margin && b.y > VH + margin) continue;
      var dAvg  = (a.depth + b.depth) * 0.5;
      var alpha = clamp(dAvg * 0.55 + 0.08, 0.05, 0.45) * oMult;
      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = 'rgba(' + purpleRgb + ',' + alpha + ')';
      ctx.lineWidth = 0.9;
      ctx.stroke();
    }

    /* ── Bridges ── */
    for (var bi = 0; bi < bridges.length; bi++) {
      var i = bridges[bi];
      if (i >= proj1.length) continue;
      var a = proj1[i], b = proj2[i];
      if ((a.y < -margin && b.y < -margin) || (a.y > VH + margin && b.y > VH + margin)) continue;
      var dAvg  = (a.depth + b.depth) * 0.5;
      var alpha = clamp(dAvg * 0.40 + 0.07, 0.06, 0.36) * oMult;

      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = 'rgba(255,255,255,' + alpha + ')';
      ctx.lineWidth = 0.5;
      ctx.stroke();

      /* Bridge endpoint dots */
      var dotAlpha = clamp(alpha * 1.8, 0, 0.5);
      ctx.beginPath();
      ctx.arc(a.x, a.y, 1.3, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255,255,255,' + dotAlpha + ')';
      ctx.fill();

      ctx.beginPath();
      ctx.arc(b.x, b.y, 1.3, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255,255,255,' + dotAlpha + ')';
      ctx.fill();
    }

    /* ── Particles strand 1 ── */
    for (var i = 0; i < proj1.length; i++) {
      var pt = proj1[i];
      if (pt.y < -margin || pt.y > VH + margin) continue;
      var mf = mouseForce(pt.x, pt.y);
      var px = pt.x + mf.dx;
      var py = pt.y + mf.dy;

      var dFade  = 0.35 + pt.depth * 0.65;
      var alpha  = clamp(dFade * 0.75, 0.08, 0.9) * oMult;
      var radius = clamp(pt.scale * HELIX_RADIUS * 0.03, 0.7, 4.5) * dFade;

      /* Glow removed — too bright, interferes with text readability */

      ctx.beginPath();
      ctx.arc(px, py, Math.max(0.5, radius), 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + accentRgb + ',' + alpha + ')';
      ctx.fill();
    }

    /* ── Particles strand 2 ── */
    for (var i = 0; i < proj2.length; i++) {
      var pt = proj2[i];
      if (pt.y < -margin || pt.y > VH + margin) continue;
      var mf = mouseForce(pt.x, pt.y);
      var px = pt.x + mf.dx;
      var py = pt.y + mf.dy;

      var dFade  = 0.35 + pt.depth * 0.65;
      var alpha  = clamp(dFade * 0.75, 0.08, 0.9) * oMult;
      var radius = clamp(pt.scale * HELIX_RADIUS * 0.03, 0.7, 4.5) * dFade;

      /* Glow removed — too bright, interferes with text readability */

      ctx.beginPath();
      ctx.arc(px, py, Math.max(0.5, radius), 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(' + purpleRgb + ',' + alpha + ')';
      ctx.fill();
    }
  }

  /* ══════════════════════════════════════════════
     MAIN LOOP
  ══════════════════════════════════════════════ */
  var lastTime = 0;
  var rafId    = null;

  function loop(ts) {
    var dt = lastTime === 0 ? 16 : Math.min(ts - lastTime, 50);
    lastTime = ts;

    /* Auto-rotation accumulates */
    autoRotY += AUTO_ROT_SPEED * dt;

    /* Scroll parallax: helix rotates slowly as user scrolls */
    var scrollRot = currentScroll * SCROLL_ROT_MULT;

    /* Total rotation */
    var totalRotY = autoRotY + scrollRot;

    /* Noise time */
    noiseTime += NOISE_SPEED * dt;

    /* Refresh accent for lang switch */
    accentRgb = getAccentRgb();

    draw(totalRotY);

    rafId = requestAnimationFrame(loop);
  }

  /* ─── Static draw (reduced motion) ─── */
  function drawStatic() {
    autoRotY = 0.3;
    draw(0.3);
  }

  /* ─── Init ─── */
  resize();

  if (reducedMotion) {
    /* Show immediately — animation is killed by prefers-reduced-motion CSS, so set opacity directly */
    container.style.opacity = '1';
    container.style.animation = 'none';
    drawStatic();
  } else {
    lastTime = performance.now();
    rafId = requestAnimationFrame(loop);
  }

  /* Cleanup on Astro view transitions */
  document.addEventListener('astro:before-swap', function () {
    if (rafId) cancelAnimationFrame(rafId);
    clearInterval(lenisCheckInterval);
  });

  /* ─── Resize (debounced) ─── */
  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      resize();
    }, 250);
  }, { passive: true });

})();
</script>

<style>
  /* ── Fixed full-page layer — IDENTICAL positioning to WireframeSphere ── */
  #dna-helix-container {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: -10;
    pointer-events: none;
    select: none;
    /* Fade in smoothly */
    opacity: 0;
    will-change: opacity;
    animation: helixFadeIn 2s ease 0.4s forwards;
    /* Protect animation from global .no-transition override during theme switch */
    animation-fill-mode: forwards;
  }

  #dna-helix-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  @keyframes helixFadeIn {
    from { opacity: 0; }
    to   { opacity: 0.6; }
  }

  @keyframes helixFadeInDark {
    from { opacity: 0; }
    to   { opacity: 0.5; }
  }

  /* Dark theme — slightly more visible but still dim */
  html.dark #dna-helix-container,
  [data-theme="dark"] #dna-helix-container {
    animation-name: helixFadeInDark;
  }

  /* Reduced motion — skip animation, show immediately */
  @media (prefers-reduced-motion: reduce) {
    #dna-helix-container {
      animation: none !important;
      opacity: 1 !important;
    }
  }

  /* Hide on tiny screens */
  @media (max-width: 400px) {
    #dna-helix-container {
      display: none;
    }
  }
</style>
