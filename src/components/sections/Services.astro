---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const servicesRegular = [
  { id: 'food',       icon: '🍰', example: false },
  { id: 'medical',    icon: '🏥', example: false },
  { id: 'auto',       icon: '🚗', example: false },
  { id: 'legal',      icon: '⚖️', example: false },
  { id: 'hotels',     icon: '🏨', example: false },
  { id: 'logistics',  icon: '📦', example: false },
  { id: 'flowers',    icon: '💐', example: false },
  { id: 'ecommerce',  icon: '🛒', example: false },
  { id: 'construction', icon: '🏗️', example: true },
  { id: 'hvac',       icon: '🌀', example: false, featured: true },
];

const servicesIT = [
  { id: 'research',   icon: '🔍', example: false },
  { id: 'bizanalytics', icon: '📊', example: false },
  { id: 'crypto',     icon: '🔐', example: true },
  { id: 'ai',         icon: '🤖', example: false },
  { id: 'telegram',   icon: '📱', example: true },
  { id: 'social',     icon: '📹', example: false, featured: true },
  { id: 'marketing',  icon: '📈', example: false },
  { id: 'finance',    icon: '🏦', example: false },
];
---

<section id="services" class="py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'services_title')} />
      <p class="text-center mb-4 text-base" style="color: var(--text-secondary);">
        {t(lang, 'services_subtitle')}
      </p>
      <p class="text-center mb-12 text-sm italic max-w-3xl mx-auto leading-relaxed" style="color: var(--text-secondary); opacity: 0.75;">
        {t(lang, 'services_disclaimer' as any)}
      </p>
    </div>

    <!-- Category 1: Regular Business -->
    <div class="reveal mb-10">
      <h2 class="category-header text-lg font-semibold mb-6 flex items-center gap-3" style="color: var(--text);">
        <span class="category-line"></span>
        {t(lang, 'services_cat_regular' as any)}
        <span class="category-line"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicesRegular.map((service, index) => (
          <div
            class={`service-card p-6 rounded-xl reveal${(service as any).featured ? ' featured-card' : ''}`}
            style={`background-color: var(--card-bg); border: 1px solid ${(service as any).featured ? 'color-mix(in srgb, var(--accent) 40%, transparent)' : 'var(--card-border)'}; box-shadow: var(--shadow-sm); transition-delay: ${index * 0.05}s;`}
          >
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0" aria-hidden="true">{service.icon}</span>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-bold mb-2" style="color: var(--text);">
                  {t(lang, `services_${service.id}_title` as any)}
                </h3>
                <p class="text-sm mb-3 leading-relaxed" style="color: var(--text-secondary);">
                  {t(lang, `services_${service.id}_desc` as any)}
                </p>
                {service.example && (
                  <div
                    class="inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full font-medium"
                    style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);"
                  >
                    <span>✓</span>
                    {t(lang, `services_${service.id}_example` as any)}
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Category 2: IT & Companies -->
    <div class="reveal mb-10">
      <h2 class="category-header text-lg font-semibold mb-6 flex items-center gap-3" style="color: var(--text);">
        <span class="category-line"></span>
        {t(lang, 'services_cat_it' as any)}
        <span class="category-line"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicesIT.map((service, index) => (
          <div
            class={`service-card p-6 rounded-xl reveal${(service as any).featured ? ' featured-card' : ''}`}
            style={`background-color: var(--card-bg); border: 1px solid ${(service as any).featured ? 'color-mix(in srgb, var(--accent) 40%, transparent)' : 'var(--card-border)'}; box-shadow: var(--shadow-sm); transition-delay: ${index * 0.05}s;`}
          >
            <div class="flex items-start gap-4">
              <span class="text-3xl flex-shrink-0" aria-hidden="true">{service.icon}</span>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-bold mb-2" style="color: var(--text);">
                  {t(lang, `services_${service.id}_title` as any)}
                </h3>
                <p class="text-sm mb-3 leading-relaxed" style="color: var(--text-secondary);">
                  {t(lang, `services_${service.id}_desc` as any)}
                </p>
                {service.example && (
                  <div
                    class="inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full font-medium"
                    style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);"
                  >
                    <span>✓</span>
                    {t(lang, `services_${service.id}_example` as any)}
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div
      class="cta-banner reveal mt-10 p-8 rounded-2xl text-center"
      style="background-color: color-mix(in srgb, var(--accent) 6%, var(--card-bg)); border: 1.5px solid color-mix(in srgb, var(--accent) 35%, transparent); box-shadow: 0 4px 24px color-mix(in srgb, var(--accent) 10%, transparent);"
    >
      <h3 class="text-xl font-bold mb-3" style="color: var(--text);">
        {t(lang, 'services_cta_title' as any)}
      </h3>
      <p class="text-base mb-6 max-w-2xl mx-auto leading-relaxed" style="color: var(--text-secondary);">
        {t(lang, 'services_cta_desc' as any)}
      </p>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all duration-200 cta-btn"
        style="background-color: var(--accent); color: #fff;"
      >
        {t(lang, 'services_cta_button' as any)}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    var els = document.querySelectorAll('#services .reveal');
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    els.forEach(function (el) { io.observe(el); });
  })();
</script>

<style>
  .service-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .service-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent) !important;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 8%, transparent);
  }
  .featured-card {
    background-color: color-mix(in srgb, var(--accent) 5%, var(--card-bg)) !important;
  }
  .cta-btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--accent) 30%, transparent);
  }
</style>
