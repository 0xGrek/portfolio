---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const servicesRegular = [
  { id: 'legal',        icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/><circle cx="12" cy="12" r="3"/></svg>`, example: false },
  { id: 'hotels',       icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22V8l9-6 9 6v14"/><path d="M9 22V12h6v10"/><rect x="9" y="6" width="6" height="4"/></svg>`, example: true, exampleUrl: 'https://lucentstays.com' },
  { id: 'construction', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="14" width="20" height="8" rx="1"/><path d="M6 14V8"/><path d="M18 14V8"/><path d="M2 10h20"/><path d="M6 6h12v2H6z"/></svg>`, example: true, exampleUrl: 'https://github.com/0xGrek/portugal-realty-dashboard' },
  { id: 'medical',      icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`, example: false },
  { id: 'food',         icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>`, example: false },
  { id: 'auto',         icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`, example: false },
];

const servicesIT = [
  { id: 'research', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`, example: false },
  { id: 'crypto',   icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`, example: false },
  { id: 'ai',       icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><path d="M14 17.5h7M17.5 14v7"/></svg>`, example: false },
];

---

<section id="services" class="py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'services_title')} />
      <p class="text-center mb-4 text-base" style="color: var(--text-secondary);">
        {t(lang, 'services_subtitle')}
      </p>
      {t(lang, 'services_disclaimer' as any) && (
        <p class="text-center mb-12 text-sm italic max-w-3xl mx-auto leading-relaxed" style="color: var(--text-secondary); opacity: 0.75;">
          {t(lang, 'services_disclaimer' as any)}
        </p>
      )}
    </div>

    <!-- Category 1: Regular Business -->
    <div class="reveal mb-10">
      <h2 class="category-header text-lg font-semibold mb-6 flex items-center gap-3" style="color: var(--text);">
        <span class="category-line"></span>
        {t(lang, 'services_cat_regular' as any)}
        <span class="category-line"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        {servicesRegular.map((service, index) => {
          const examplesRaw = t(lang, `services_${service.id}_examples` as any) as string | undefined;
          const examplesParts = examplesRaw ? examplesRaw.split('|') : [];
          const examplesHeader = examplesParts[0] ?? '';
          const examplesBullets = examplesParts.slice(1);
          return (
            <div
              class={`service-card p-6 rounded-xl${(service as any).featured ? ' featured-card' : ''}`}
              style={`background-color: var(--card-bg); border: 1px solid ${(service as any).featured ? 'color-mix(in srgb, var(--accent) 40%, transparent)' : 'var(--card-border)'}; box-shadow: var(--shadow-sm);`}
            >
              <div class="flex items-start gap-4">
                <span class="service-icon flex-shrink-0" aria-hidden="true" set:html={service.icon} />
                <div class="flex-1 min-w-0">
                  <h3 class="text-base font-bold mb-2" style="color: var(--text);">
                    {t(lang, `services_${service.id}_title` as any)}
                  </h3>
                  <p class="card-intro text-sm mb-3 leading-relaxed" style="color: var(--text-secondary);">
                    {t(lang, `services_${service.id}_desc` as any)}
                  </p>
                  {examplesBullets.length > 0 && (
                    <div class="card-details">
                      {examplesHeader && (
                        <p class="text-xs font-semibold mb-1" style="color: var(--text-secondary); opacity: 0.7;">{examplesHeader}</p>
                      )}
                      <ul>
                        {examplesBullets.map((bullet) => (
                          <li>{bullet}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                  {service.example && (
                    (service as any).exampleUrl ? (
                      <a
                        href={(service as any).exampleUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="example-badge inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full font-medium mt-1"
                        style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent); text-decoration: none;"
                      >
                        <span>✓</span>
                        {t(lang, `services_${service.id}_example` as any)}
                        <span class="example-badge-arrow" aria-hidden="true">↗</span>
                      </a>
                    ) : (
                      <div
                        class="inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full font-medium mt-1"
                        style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);"
                      >
                        <span>✓</span>
                        {t(lang, `services_${service.id}_example` as any)}
                      </div>
                    )
                  )}
                </div>
              </div>
              {examplesBullets.length > 0 && (
                <div class="flex justify-center mt-3">
                  <svg class="card-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>

    <!-- Category 2: IT & Companies -->
    <div class="reveal mb-10">
      <h2 class="category-header text-lg font-semibold mb-6 flex items-center gap-3" style="color: var(--text);">
        <span class="category-line"></span>
        {t(lang, 'services_cat_it' as any)}
        <span class="category-line"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
        {servicesIT.map((service, index) => {
          const examplesRaw = t(lang, `services_${service.id}_examples` as any) as string | undefined;
          const examplesParts = examplesRaw ? examplesRaw.split('|') : [];
          const examplesHeader = examplesParts[0] ?? '';
          const examplesBullets = examplesParts.slice(1);
          return (
            <div
              class={`service-card p-6 rounded-xl${(service as any).featured ? ' featured-card' : ''}`}
              style={`background-color: var(--card-bg); border: 1px solid ${(service as any).featured ? 'color-mix(in srgb, var(--accent) 40%, transparent)' : 'var(--card-border)'}; box-shadow: var(--shadow-sm);`}
            >
              <div class="flex items-start gap-4">
                <span class="service-icon flex-shrink-0" aria-hidden="true" set:html={service.icon} />
                <div class="flex-1 min-w-0">
                  <h3 class="text-base font-bold mb-2" style="color: var(--text);">
                    {t(lang, `services_${service.id}_title` as any)}
                  </h3>
                  <p class="card-intro text-sm mb-3 leading-relaxed" style="color: var(--text-secondary);">
                    {t(lang, `services_${service.id}_desc` as any)}
                  </p>
                  {examplesBullets.length > 0 && (
                    <div class="card-details">
                      {examplesHeader && (
                        <p class="text-xs font-semibold mb-1" style="color: var(--text-secondary); opacity: 0.7;">{examplesHeader}</p>
                      )}
                      <ul>
                        {examplesBullets.map((bullet) => (
                          <li>{bullet}</li>
                        ))}
                      </ul>
                    </div>
                  )}
                  {service.example && (
                    (service as any).exampleUrl ? (
                      <a
                        href={(service as any).exampleUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="example-badge inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full font-medium mt-1"
                        style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent); text-decoration: none;"
                      >
                        <span>✓</span>
                        {t(lang, `services_${service.id}_example` as any)}
                        <span class="example-badge-arrow" aria-hidden="true">↗</span>
                      </a>
                    ) : (
                      <div
                        class="inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full font-medium mt-1"
                        style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);"
                      >
                        <span>✓</span>
                        {t(lang, `services_${service.id}_example` as any)}
                      </div>
                    )
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <div
      class="cta-banner reveal mt-10 p-8 rounded-2xl text-center"
      style="background-color: color-mix(in srgb, var(--accent) 6%, var(--card-bg)); border: 1.5px solid color-mix(in srgb, var(--accent) 35%, transparent); box-shadow: 0 4px 24px color-mix(in srgb, var(--accent) 10%, transparent);"
    >
      <h3 class="text-xl font-bold mb-3" style="color: var(--text);">
        {t(lang, 'services_cta_title' as any)}
      </h3>
      <p class="text-base mb-6 max-w-2xl mx-auto leading-relaxed" style="color: var(--text-secondary);">
        {t(lang, 'services_cta_desc' as any)}
      </p>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all duration-200 cta-btn"
        style="background-color: var(--accent); color: #fff;"
      >
        {t(lang, 'services_cta_button' as any)}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    /* Section reveal elements */
    var els = document.querySelectorAll('#services .reveal');
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    els.forEach(function (el) { io.observe(el); });

    /* Stagger grids */
    var staggerGrids = document.querySelectorAll('#services .stagger-children');
    var staggerIo = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          staggerIo.unobserve(e.target);
        }
      });
    }, { threshold: 0.06 });
    staggerGrids.forEach(function (el) { staggerIo.observe(el); });

    /* Mobile tap-to-expand for card details */
    var isTouchDevice = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);
    if (isTouchDevice) {
      document.querySelectorAll('#services .service-card').forEach(function (card) {
        card.addEventListener('click', function () {
          var details = card.querySelector('.card-details');
          if (details) {
            details.classList.toggle('expanded');
          }
        });
      });
    }

    /* Desktop hover-with-delay for card details — prevents flicker when moving between cards */
    if (!isTouchDevice) {
      document.querySelectorAll('#services .service-card').forEach(function (card) {
        var details = card.querySelector('.card-details');
        if (!details) return;
        var enterTimer = null;
        var leaveTimer = null;

        card.addEventListener('mouseenter', function () {
          clearTimeout(leaveTimer);
          leaveTimer = null;
          enterTimer = setTimeout(function () {
            details.classList.add('expanded');
          }, 200);
        });

        card.addEventListener('mouseleave', function () {
          clearTimeout(enterTimer);
          enterTimer = null;
          leaveTimer = setTimeout(function () {
            details.classList.remove('expanded');
          }, 350);
        });
      });
    }
  })();
</script>

<style>
  .service-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    color: var(--accent);
    opacity: 0.85;
    margin-top: 2px;
  }
  .service-icon svg {
    width: 28px;
    height: 28px;
  }
  .service-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .service-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent) !important;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 8%, transparent);
  }
  .featured-card {
    background-color: color-mix(in srgb, var(--accent) 5%, var(--card-bg)) !important;
  }
  .cta-btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .category-header {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    opacity: 0.65;
  }
  .category-line {
    flex: 1;
    height: 1px;
    background-color: var(--card-border);
  }
  .example-badge {
    transition: background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    cursor: pointer;
  }
  .example-badge:hover {
    background-color: color-mix(in srgb, var(--accent) 22%, transparent) !important;
    border-color: color-mix(in srgb, var(--accent) 50%, transparent) !important;
    transform: translateY(-1px);
  }
  .example-badge-arrow {
    font-size: 0.7rem;
    opacity: 0.7;
  }
  .card-details {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .card-details.expanded {
    max-height: 300px;
  }
  .card-details ul {
    list-style: none;
    padding: 0;
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
  }
  .card-details li {
    padding: 0.2rem 0;
    padding-left: 1rem;
    position: relative;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--text-secondary);
  }
  .card-details li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
</style>
