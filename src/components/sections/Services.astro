---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const servicesRegular = [
  { id: 'food',         icon: '🍰', example: false },
  { id: 'medical',      icon: '🏥', example: false },
  { id: 'auto',         icon: '🚗', example: false },
  { id: 'legal',        icon: '⚖️', example: false },
  { id: 'hotels',       icon: '🏨', example: true, exampleUrl: 'https://lucentstays.com' },
  { id: 'construction', icon: '🏗️', example: true, exampleUrl: 'https://github.com/0xGrek/portugal-realty-dashboard' },
];

const servicesIT = [
  { id: 'research', icon: '🔍', example: false },
  { id: 'crypto',   icon: '🔐', example: false },
  { id: 'ai',       icon: '🤖', example: false },
];

const showMoreText = t(lang, 'services_show_more' as any);
const showLessText = t(lang, 'services_show_less' as any);
---

<section id="services" class="py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'services_title')} />
      <p class="text-center mb-4 text-base" style="color: var(--text-secondary);">
        {t(lang, 'services_subtitle')}
      </p>
      {t(lang, 'services_disclaimer' as any) && (
        <p class="text-center mb-12 text-sm italic max-w-3xl mx-auto leading-relaxed" style="color: var(--text-secondary); opacity: 0.75;">
          {t(lang, 'services_disclaimer' as any)}
        </p>
      )}
    </div>

    <!-- Category 1: Regular Business -->
    <div class="reveal mb-10">
      <h2 class="category-header text-lg font-semibold mb-6 flex items-center gap-3" style="color: var(--text);">
        <span class="category-line"></span>
        {t(lang, 'services_cat_regular' as any)}
        <span class="category-line"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicesRegular.map((service, index) => {
          const examplesRaw = t(lang, `services_${service.id}_examples` as any) as string | undefined;
          const examplesParts = examplesRaw ? examplesRaw.split('|') : [];
          const examplesHeader = examplesParts[0] ?? '';
          const examplesBullets = examplesParts.slice(1);
          return (
            <div
              class={`service-card p-6 rounded-xl reveal${(service as any).featured ? ' featured-card' : ''}`}
              style={`background-color: var(--card-bg); border: 1px solid ${(service as any).featured ? 'color-mix(in srgb, var(--accent) 40%, transparent)' : 'var(--card-border)'}; box-shadow: var(--shadow-sm); transition-delay: ${index * 0.05}s;`}
            >
              <div class="flex items-start gap-4">
                <span class="text-3xl flex-shrink-0" aria-hidden="true">{service.icon}</span>
                <div class="flex-1 min-w-0">
                  <h3 class="text-base font-bold mb-2" style="color: var(--text);">
                    {t(lang, `services_${service.id}_title` as any)}
                  </h3>
                  <p class="card-intro text-sm mb-3 leading-relaxed" style="color: var(--text-secondary);">
                    {t(lang, `services_${service.id}_desc` as any)}
                  </p>
                  {examplesBullets.length > 0 && (
                    <>
                      <button
                        class="show-more-btn text-xs font-medium mb-2 px-0"
                        data-target={`details-${service.id}-${index}`}
                        data-show-more={showMoreText}
                        data-show-less={showLessText}
                        style="color: var(--accent); background: none; border: none; cursor: pointer; padding: 0; display: inline-flex; align-items: center; gap: 0.25rem;"
                      >
                        {showMoreText}
                      </button>
                      <div class="card-details" id={`details-${service.id}-${index}`}>
                        {examplesHeader && (
                          <p class="text-xs font-semibold mb-1" style="color: var(--text-secondary); opacity: 0.7;">{examplesHeader}</p>
                        )}
                        <ul>
                          {examplesBullets.map((bullet) => (
                            <li>{bullet}</li>
                          ))}
                        </ul>
                      </div>
                    </>
                  )}
                  {service.example && (
                    (service as any).exampleUrl ? (
                      <a
                        href={(service as any).exampleUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="example-badge inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full font-medium mt-1"
                        style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent); text-decoration: none;"
                      >
                        <span>✓</span>
                        {t(lang, `services_${service.id}_example` as any)}
                        <span class="example-badge-arrow" aria-hidden="true">↗</span>
                      </a>
                    ) : (
                      <div
                        class="inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full font-medium mt-1"
                        style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);"
                      >
                        <span>✓</span>
                        {t(lang, `services_${service.id}_example` as any)}
                      </div>
                    )
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Category 2: IT & Companies -->
    <div class="reveal mb-10">
      <h2 class="category-header text-lg font-semibold mb-6 flex items-center gap-3" style="color: var(--text);">
        <span class="category-line"></span>
        {t(lang, 'services_cat_it' as any)}
        <span class="category-line"></span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {servicesIT.map((service, index) => {
          const examplesRaw = t(lang, `services_${service.id}_examples` as any) as string | undefined;
          const examplesParts = examplesRaw ? examplesRaw.split('|') : [];
          const examplesHeader = examplesParts[0] ?? '';
          const examplesBullets = examplesParts.slice(1);
          return (
            <div
              class={`service-card p-6 rounded-xl reveal${(service as any).featured ? ' featured-card' : ''}`}
              style={`background-color: var(--card-bg); border: 1px solid ${(service as any).featured ? 'color-mix(in srgb, var(--accent) 40%, transparent)' : 'var(--card-border)'}; box-shadow: var(--shadow-sm); transition-delay: ${index * 0.05}s;`}
            >
              <div class="flex items-start gap-4">
                <span class="text-3xl flex-shrink-0" aria-hidden="true">{service.icon}</span>
                <div class="flex-1 min-w-0">
                  <h3 class="text-base font-bold mb-2" style="color: var(--text);">
                    {t(lang, `services_${service.id}_title` as any)}
                  </h3>
                  <p class="card-intro text-sm mb-3 leading-relaxed" style="color: var(--text-secondary);">
                    {t(lang, `services_${service.id}_desc` as any)}
                  </p>
                  {examplesBullets.length > 0 && (
                    <>
                      <button
                        class="show-more-btn text-xs font-medium mb-2"
                        data-target={`details-${service.id}-${index + 100}`}
                        data-show-more={showMoreText}
                        data-show-less={showLessText}
                        style="color: var(--accent); background: none; border: none; cursor: pointer; padding: 0; display: inline-flex; align-items: center; gap: 0.25rem;"
                      >
                        {showMoreText}
                      </button>
                      <div class="card-details" id={`details-${service.id}-${index + 100}`}>
                        {examplesHeader && (
                          <p class="text-xs font-semibold mb-1" style="color: var(--text-secondary); opacity: 0.7;">{examplesHeader}</p>
                        )}
                        <ul>
                          {examplesBullets.map((bullet) => (
                            <li>{bullet}</li>
                          ))}
                        </ul>
                      </div>
                    </>
                  )}
                  {service.example && (
                    (service as any).exampleUrl ? (
                      <a
                        href={(service as any).exampleUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="example-badge inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full font-medium mt-1"
                        style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent); text-decoration: none;"
                      >
                        <span>✓</span>
                        {t(lang, `services_${service.id}_example` as any)}
                        <span class="example-badge-arrow" aria-hidden="true">↗</span>
                      </a>
                    ) : (
                      <div
                        class="inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full font-medium mt-1"
                        style="background-color: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);"
                      >
                        <span>✓</span>
                        {t(lang, `services_${service.id}_example` as any)}
                      </div>
                    )
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <div
      class="cta-banner reveal mt-10 p-8 rounded-2xl text-center"
      style="background-color: color-mix(in srgb, var(--accent) 6%, var(--card-bg)); border: 1.5px solid color-mix(in srgb, var(--accent) 35%, transparent); box-shadow: 0 4px 24px color-mix(in srgb, var(--accent) 10%, transparent);"
    >
      <h3 class="text-xl font-bold mb-3" style="color: var(--text);">
        {t(lang, 'services_cta_title' as any)}
      </h3>
      <p class="text-base mb-6 max-w-2xl mx-auto leading-relaxed" style="color: var(--text-secondary);">
        {t(lang, 'services_cta_desc' as any)}
      </p>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all duration-200 cta-btn"
        style="background-color: var(--accent); color: #fff;"
      >
        {t(lang, 'services_cta_button' as any)}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    var els = document.querySelectorAll('#services .reveal');
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.08 });
    els.forEach(function (el) { io.observe(el); });
  })();

  document.querySelectorAll('.show-more-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var targetId = btn.getAttribute('data-target');
      var showMore = btn.getAttribute('data-show-more');
      var showLess = btn.getAttribute('data-show-less');
      var details = document.getElementById(targetId);
      if (!details) return;
      var isExpanded = details.classList.contains('expanded');
      details.classList.toggle('expanded');
      btn.textContent = isExpanded ? showMore : showLess;
    });
  });
</script>

<style>
  .service-card {
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .service-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 40%, transparent) !important;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 8%, transparent);
  }
  .featured-card {
    background-color: color-mix(in srgb, var(--accent) 5%, var(--card-bg)) !important;
  }
  .cta-btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .category-header {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    opacity: 0.65;
  }
  .category-line {
    flex: 1;
    height: 1px;
    background-color: var(--card-border);
  }
  .show-more-btn {
    transition: opacity 0.15s ease;
  }
  .show-more-btn:hover {
    opacity: 0.7;
  }
  .example-badge {
    transition: background-color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    cursor: pointer;
  }
  .example-badge:hover {
    background-color: color-mix(in srgb, var(--accent) 22%, transparent) !important;
    border-color: color-mix(in srgb, var(--accent) 50%, transparent) !important;
    transform: translateY(-1px);
  }
  .example-badge-arrow {
    font-size: 0.7rem;
    opacity: 0.7;
  }
  .card-details {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .card-details.expanded {
    max-height: 500px;
  }
  .card-details ul {
    list-style: none;
    padding: 0;
    margin-top: 0.25rem;
    margin-bottom: 0.5rem;
  }
  .card-details li {
    padding: 0.2rem 0;
    padding-left: 1rem;
    position: relative;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--text-secondary);
  }
  .card-details li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
</style>
