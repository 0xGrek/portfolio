---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import Button from '../ui/Button.astro';
import WireframeSphere from '../ui/WireframeSphere.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const socials = [
  { name: 'GitHub', href: 'https://github.com/0xGrek', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>` },
  { name: 'LinkedIn', href: 'https://linkedin.com/in/ivanenko-pt', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>` },
  { name: 'X', href: 'https://x.com/0xGrek', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>` },
  { name: 'Telegram', href: 'https://t.me/OxGrek', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>` },
];
---

<section
  id="hero"
  class="relative min-h-screen flex items-center pt-16 overflow-hidden"
  style="background-color: transparent;"
>
  <!-- Animated gradient background -->
  <div class="absolute inset-0 pointer-events-none hero-animated-bg"></div>
  <!-- Dot-grid background pattern -->
  <div
    class="absolute inset-0 pointer-events-none hero-dots"
  ></div>
  <!-- Gradient overlay top/bottom -->
  <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to bottom, var(--bg) 0%, transparent 18%, transparent 80%, var(--bg) 100%);"></div>
  <!-- Radial glow center — stronger, layered -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 70% 60% at 50% 40%, rgba(var(--accent-rgb), 0.07) 0%, rgba(var(--accent-rgb), 0.02) 40%, transparent 70%);"></div>
  <!-- Floating particles (CSS only) -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden hero-particles" aria-hidden="true">
    <span class="particle particle-1"></span>
    <span class="particle particle-2"></span>
    <span class="particle particle-3"></span>
    <span class="particle particle-4"></span>
    <span class="particle particle-5"></span>
    <span class="particle particle-6"></span>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Text content -->
      <div class="space-y-6 hero-content">
        <!-- Greeting -->
        <p class="text-lg font-mono hero-greeting" style="color: var(--accent);">
          {t(lang, 'hero_greeting')}
        </p>

        <!-- Name + handle -->
        <div>
          <h1 class="text-fluid-hero font-bold leading-tight gradient-text hero-typewriter" style="letter-spacing: -0.02em;" data-text={t(lang, 'hero_name')}>
            {t(lang, 'hero_name')}
          </h1>
          <p class="text-xl sm:text-2xl font-mono mt-1" style="color: var(--text-secondary);">
            {t(lang, 'hero_handle')}
          </p>
        </div>

        <!-- Title / Subtitle -->
        <div class="space-y-1">
          <p class="text-lg sm:text-xl font-bold leading-snug hero-subtitle-lead" style="color: var(--text);">
            {t(lang, 'hero_subtitle_lead')}
          </p>
          <p class="text-base sm:text-lg font-normal leading-relaxed hero-subtitle-body" style="color: var(--text-secondary);">
            {t(lang, 'hero_subtitle_body')}
          </p>
        </div>

        <!-- Status badges -->
        <div class="flex flex-wrap gap-3">
          <span
            class="flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium"
            style="background-color: rgba(63,185,80,0.12); color: #3fb950; border: 1px solid rgba(63,185,80,0.35); animation: pulseGlow 2.8s ease-in-out infinite;"
          >
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
            {t(lang, 'hero_available')}
          </span>
          <span class="flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-medium" style="background-color: var(--bg-secondary); color: var(--text-secondary); border: 1px solid var(--border);">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <a
              href="https://www.google.com/maps/place/Lisbon,+Portugal"
              target="_blank"
              rel="noopener noreferrer"
              class="location-link"
              style="text-decoration: none;"
            >{t(lang, 'hero_location')}</a>
          </span>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4">
          <Button href="#projects" variant="primary" size="lg" class="magnetic">
            {t(lang, 'hero_cta_projects')}
          </Button>
          <Button href="#footer" variant="secondary" size="lg" class="magnetic">
            {t(lang, 'hero_cta_contact')}
          </Button>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-4 pt-2">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
              class={`magnetic social-hover social-hero--${s.name.toLowerCase().replace(/[^a-z]/g, '')}`}
              style="color: var(--text-secondary); display: inline-flex;"
            >
              <Fragment set:html={s.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Right: Avatar + WireframeSphere -->
      <div class="flex justify-center lg:justify-end order-first lg:order-last">
        <div class="relative">
          <!-- Wireframe sphere — absolutely positioned, centered behind avatar, overflows -->
          <div class="absolute" style="z-index: 1; pointer-events: none; top: 50%; left: 50%; transform: translate(-50%, -50%);">
            <WireframeSphere />
          </div>
          <!-- Glow effect — layered for depth -->
          <div
            class="absolute inset-0 rounded-full blur-3xl opacity-30"
            style="background: radial-gradient(circle, var(--accent) 0%, rgba(var(--accent-rgb), 0.3) 60%, transparent 100%); transform: scale(1.4);"
          ></div>
          <!-- Avatar circle -->
          <div
            class="relative w-40 h-40 sm:w-56 sm:h-56 lg:w-72 lg:h-72 rounded-full flex items-center justify-center text-4xl sm:text-5xl lg:text-7xl font-bold border-2 avatar-ring"
            style="background-color: var(--bg-secondary); border-color: var(--border);"
          >
            <span class="gradient-text">SI</span>
          </div>
          <!-- Decorative spinning ring -->
          <div
            class="absolute inset-0 rounded-full border-2"
            style="border-color: transparent; border-top-color: var(--accent); opacity: 0.4; animation: spin-slow 8s linear infinite; transform: scale(1.12);"
          ></div>
          <!-- Second ring opposite -->
          <div
            class="absolute inset-0 rounded-full border"
            style="border-color: transparent; border-bottom-color: rgba(var(--accent-rgb), 0.3); animation: spin-slow 12s linear infinite reverse; transform: scale(1.2);"
          ></div>
        </div>
      </div>
    </div>

    <!-- Scroll-down indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 no-print">
      <span class="text-xs font-mono" style="color: var(--text-secondary); opacity: 0.6;">scroll</span>
      <svg
        class="animate-bounce-scroll"
        xmlns="http://www.w3.org/2000/svg"
        width="16" height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        style="color: var(--text-secondary); opacity: 0.5;"
      >
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </div>
</section>

<style>
  /* Animated gradient background */
  .hero-animated-bg {
    background: linear-gradient(
      135deg,
      rgba(var(--accent-rgb), 0.04) 0%,
      rgba(163, 113, 247, 0.03) 25%,
      rgba(var(--accent-rgb), 0.02) 50%,
      rgba(88, 166, 255, 0.04) 75%,
      rgba(var(--accent-rgb), 0.03) 100%
    );
    background-size: 400% 400%;
    animation: hero-gradient-shift 18s ease infinite;
  }

  .hero-dots {
    background-image:
      radial-gradient(circle, rgba(var(--accent-rgb), 0.08) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.8;
  }

  /* Floating particles */
  .particle {
    position: absolute;
    border-radius: 50%;
    background: rgba(var(--accent-rgb), 0.25);
    pointer-events: none;
  }
  .particle-1 { width: 4px; height: 4px; top: 15%; left: 12%; animation: float-particle 6s ease-in-out infinite; }
  .particle-2 { width: 3px; height: 3px; top: 28%; left: 85%; animation: float-particle 8s ease-in-out infinite 1.2s; background: rgba(163, 113, 247, 0.3); }
  .particle-3 { width: 5px; height: 5px; top: 65%; left: 8%;  animation: float-particle 7s ease-in-out infinite 0.6s; }
  .particle-4 { width: 3px; height: 3px; top: 72%; left: 78%; animation: float-particle 9s ease-in-out infinite 2s; background: rgba(88, 166, 255, 0.35); }
  .particle-5 { width: 4px; height: 4px; top: 42%; left: 92%; animation: float-particle 6.5s ease-in-out infinite 3s; }
  .particle-6 { width: 3px; height: 3px; top: 55%; left: 22%; animation: float-particle 10s ease-in-out infinite 1.5s; background: rgba(163, 113, 247, 0.25); }

  @media (max-width: 768px) {
    .hero-particles { display: none; }
    .hero-animated-bg { animation-duration: 30s; }
  }

  /* Staggered fade-in for hero content */
  .hero-content > * {
    animation: fade-in-up 0.65s cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  .hero-content > *:nth-child(1) { animation-delay: 0.05s; }
  .hero-content > *:nth-child(2) { animation-delay: 0.18s; }
  .hero-content > *:nth-child(3) { animation-delay: 0.3s; }
  .hero-content > *:nth-child(4) { animation-delay: 0.4s; }
  .hero-content > *:nth-child(5) { animation-delay: 0.5s; }
  .hero-content > *:nth-child(6) { animation-delay: 0.6s; }
  .hero-content > *:nth-child(7) { animation-delay: 0.7s; }

  /* Subtitle lines — extra slight blur-to-sharp effect */
  .hero-subtitle-lead {
    animation: fade-in-up 0.65s cubic-bezier(0.4, 0, 0.2, 1) 0.3s both,
               hero-blur-in 0.8s ease 0.3s both;
  }
  .hero-subtitle-body {
    animation: fade-in-up 0.65s cubic-bezier(0.4, 0, 0.2, 1) 0.42s both,
               hero-blur-in 0.8s ease 0.42s both;
  }

  .avatar-ring {
    transition: box-shadow 0.35s ease, border-color 0.35s ease;
  }
  .avatar-ring:hover {
    box-shadow: 0 0 0 4px rgba(var(--accent-rgb), 0.15),
                0 0 40px rgba(var(--accent-rgb), 0.3),
                0 0 80px rgba(var(--accent-rgb), 0.12);
    border-color: var(--accent) !important;
  }

  .location-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }
  .location-link:hover {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: rgba(var(--accent-rgb), 0.6);
  }

  /* Platform-specific hover colors for hero socials */
  .social-hero--github:hover { color: #e6edf3 !important; transform: scale(1.18) rotate(-5deg) !important; }
  .social-hero--linkedin:hover { color: #0a66c2 !important; }
  .social-hero--x:hover { color: #e7e9ea !important; transform: scale(1.18) rotate(-5deg) !important; }
  .social-hero--telegram:hover { color: #26a5e4 !important; }
</style>
