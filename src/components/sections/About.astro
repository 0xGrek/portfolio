---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const stats = [
  { value: 'stat_tools', label: 'stat_tools_label' },
  { value: 'stat_chains', label: 'stat_chains_label' },
  { value: 'stat_years', label: 'stat_years_label' },
  { value: 'stat_exchanges', label: 'stat_exchanges_label' },
] as const;
---

<section id="about" class="py-24" style="background-color: var(--bg);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'about_title')} />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Left: Text -->
      <div class="space-y-5 reveal">
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_p1')}
        </p>
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_p2')}
        </p>
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_p3')}
        </p>

        <!-- Callout / unique quote -->
        <blockquote
          class="about-quote mt-6 p-5 rounded-lg border-l-4 italic"
          style="background-color: var(--bg-secondary); border-color: var(--accent); color: var(--text);"
        >
          {t(lang, 'about_unique')}
        </blockquote>
      </div>

      <!-- Right: Stats grid -->
      <div class="grid grid-cols-2 gap-4 reveal">
        {stats.map((stat, i) => (
          <div
            class="stat-card p-6 rounded-xl text-center card-hover reveal"
            style={`background-color: var(--card-bg); border: 1px solid var(--card-border); transition-delay: ${i * 0.1}s;`}
          >
            <div class="stat-value text-3xl sm:text-4xl font-bold mb-2" style="color: var(--accent);">
              {t(lang, stat.value)}
            </div>
            <div class="text-sm" style="color: var(--text-secondary);">
              {t(lang, stat.label)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-quote {
    position: relative;
    transition: box-shadow 0.2s ease;
  }
  .about-quote::before {
    content: '"';
    position: absolute;
    top: -8px;
    left: 12px;
    font-size: 3rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.3;
    font-style: normal;
    font-family: Georgia, serif;
  }
  /* Pop animation triggers on the stat value when parent becomes visible */
  .stat-card.visible .stat-value,
  .stat-card.active .stat-value {
    animation: valPop 0.6s ease forwards;
  }
</style>

