---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const stats = [
  { value: 'about_stats_tools' },
  { value: 'about_stats_chains' },
  { value: 'about_stats_web3' },
  { value: 'about_stats_police' },
] as const;
---

<section id="about" class="py-24" style="background-color: var(--bg);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'about_title')} />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Left: Text -->
      <div class="space-y-5 reveal">
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_text_1')}
        </p>
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_text_2')}
        </p>
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_text_3')}
        </p>
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_text_4')}
        </p>
      </div>

      <!-- Right: Stats grid -->
      <div class="grid grid-cols-2 gap-4 reveal">
        {stats.map((stat, i) => (
          <div
            class="stat-card p-6 rounded-xl text-center card-hover reveal glass-card"
            style={`border: 1px solid var(--card-border); transition-delay: ${i * 0.1}s;`}
          >
            <div class="stat-value text-3xl sm:text-4xl font-bold mb-2" style="color: var(--accent);">
              {t(lang, stat.value)}
            </div>
            <div class="text-sm" style="color: var(--text-secondary); line-height: 1.5;">
              {t(lang, stat.label)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-quote {
    position: relative;
    transition: box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .about-quote:hover {
    box-shadow: 0 4px 20px rgba(var(--accent-rgb), 0.1);
    border-color: rgba(var(--accent-rgb), 0.6) !important;
  }
  .about-quote::before {
    content: '"';
    position: absolute;
    top: -8px;
    left: 12px;
    font-size: 3rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.3;
    font-style: normal;
    font-family: Georgia, serif;
  }
  /* Pop animation triggers on the stat value when parent becomes visible */
  .stat-card.visible .stat-value,
  .stat-card.active .stat-value {
    animation: valPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  /* Radial glow on stat card hover */
  .stat-card {
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.25s ease,
                border-color 0.25s ease;
  }
  .stat-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at 50% 50%, rgba(var(--accent-rgb), 0.08), transparent 70%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 0;
  }
  .stat-card:hover::after {
    opacity: 1;
  }
  .stat-card > * {
    position: relative;
    z-index: 1;
  }
</style>

