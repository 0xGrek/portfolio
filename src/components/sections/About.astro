---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const stats = [
  { value: 'about_stats_tools' },
  { value: 'about_stats_chains' },
  { value: 'about_stats_web3' },
  { value: 'about_stats_police' },
] as const;
---

<section id="about" class="py-24" style="background-color: transparent;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'about_title')} />
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <!-- Left: Text -->
      <div class="space-y-5 reveal">
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_text_1')}
        </p>
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_text_2')}
        </p>
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_text_3')}
        </p>
        <p class="text-base leading-relaxed" style="color: var(--text-secondary);">
          {t(lang, 'about_text_4')}
        </p>
      </div>

      <!-- Right: Stats grid -->
      <div class="grid grid-cols-2 gap-4 stagger-children justify-items-center mx-auto w-full max-w-md lg:max-w-none" style="grid-auto-rows: 1fr;">
        {stats.map((stat, i) => (
          <div
            class="stat-card p-4 sm:p-5 rounded-xl text-center card-hover glass-card w-full flex items-center justify-center"
            style={`border: 1px solid var(--card-border); min-height: 80px;`}
          >
            <div class="stat-value font-bold w-full">
              {t(lang, stat.value as any)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Scroll-reveal handled by global IntersectionObserver in BaseLayout.astro -->

<style>
  /* Flexible stat text — adapts to card size, never overflows */
  .stat-value {
    color: var(--accent);
    font-size: clamp(0.75rem, 2.5vw + 0.25rem, 1.125rem);
    line-height: 1.3;
    overflow-wrap: break-word;
    word-break: break-word;
    hyphens: auto;
    text-wrap: balance;
    text-align: center;
  }

  /* Pop animation — triggers when stagger-children container becomes visible */
  .stagger-children.visible .stat-card .stat-value {
    animation: valPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s both;
  }
  /* Radial glow on stat card hover */
  .stat-card {
    position: relative;
    /* Non-interactive display card — override card-hover cursor */
    cursor: default;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.25s ease,
                border-color 0.25s ease;
  }
  .stat-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at 50% 50%, rgba(var(--accent-rgb), 0.08), transparent 70%);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 0;
  }
  .stat-card:hover::after {
    opacity: 1;
  }
  .stat-card > * {
    position: relative;
    z-index: 1;
  }
</style>

