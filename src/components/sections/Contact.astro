---

<section id="contact" class="py-24" style="background-color: var(--bg-secondary);">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="reveal">
      <SectionTitle
        title={t(lang, 'contact_title')}
        subtitle={t(lang, 'contact_subtitle')}
      />
    </div>

    <!-- Available badge + location -->
    <div class="flex flex-wrap items-center justify-center gap-3 mb-10 reveal">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full pulse-green-glow"
        style="background-color: rgba(63,185,80,0.12); color: #3fb950; border: 1px solid rgba(63,185,80,0.35);"
      >
        <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        <span class="text-sm font-medium">{t(lang, 'contact_available')}</span>
      </div>

      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm"
        style="background-color: var(--bg); color: var(--text-secondary); border: 1px solid var(--border);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        <a
          href="https://www.google.com/maps/place/Lisbon,+Portugal"
          target="_blank"
          rel="noopener noreferrer"
          class="location-link"
        >Lisbon, Portugal</a> · Remote-ready worldwide
      </div>
    </div>

    <!-- Social link cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {socials.map((s, index) => (
        <a
          href={s.href}
          target={s.external ? '_blank' : undefined}
          rel={s.external ? 'noopener noreferrer' : undefined}
          aria-label={s.name}
          class="social-card group flex items-center gap-4 px-5 py-4 rounded-xl text-left reveal"
          style={`background-color: var(--card-bg); border: 1px solid ${s.borderColor}; transition-delay: ${index * 0.07}s;`}
        >
          <!-- Icon -->
          <div
            class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center"
            style={`background-color: ${s.color}; color: ${s.iconColor};`}
          >
            <Fragment set:html={s.icon} />
          </div>

          <!-- Text -->
          <div class="min-w-0 flex-1 text-left">
            <p class="text-xs font-semibold uppercase tracking-wider mb-0.5" style="color: var(--text-secondary);">
              {s.name}
            </p>
            <p class="text-sm font-medium truncate" style="color: var(--text);">
              {s.label}
            </p>
          </div>

          <!-- Arrow -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="flex-shrink-0 social-card-arrow"
            style="color: var(--accent);"
          >
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .social-card {
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.25s ease,
                border-color 0.25s ease;
    box-shadow: var(--shadow-sm);
    position: relative;
    overflow: hidden;
  }
  .social-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 40%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
    transform: translateX(-100%) skewX(-12deg);
    pointer-events: none;
    z-index: 1;
  }
  .social-card:hover::before {
    animation: shine-sweep 0.55s ease forwards;
  }
  .social-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-md), 0 0 0 1px rgba(var(--accent-rgb), 0.2);
    border-color: rgba(var(--accent-rgb), 0.45) !important;
  }
  .social-card:active {
    transform: translateY(-2px);
    transition-duration: 0.1s;
  }
  .social-card-arrow {
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.2s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .social-card:hover .social-card-arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>

