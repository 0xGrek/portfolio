---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import { education } from '../../data/education';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const statusStyles: Record<string, string> = {
  completed: 'background-color: rgba(63,185,80,0.1); color: #3fb950; border-color: rgba(63,185,80,0.3);',
  pending: 'background-color: rgba(255,166,87,0.1); color: #ffa657; border-color: rgba(255,166,87,0.3);',
  'in-progress': 'background-color: rgba(88,166,255,0.1); color: var(--accent); border-color: rgba(88,166,255,0.3);',
};

const statusLabels: Record<string, string> = {
  completed: 'Completed',
  pending: 'Exam Pending',
  'in-progress': 'In Progress',
};

---

<section id="education" class="py-20" style="background-color: var(--bg);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionTitle title={t(lang, 'education_title')} />

    <!-- Education cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {education.map((edu) => (
        <div
          class="relative p-5 rounded-xl flex flex-col"
          style="background-color: var(--card-bg); border: 1px solid var(--card-border);"
        >
          <!-- Type icon -->
          <div class="flex items-start justify-between mb-4">
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center text-lg"
              style="background-color: var(--bg-secondary);"
            >
              {edu.type === 'degree' ? '🎓' : '📜'}
            </div>
            <!-- Status badge -->
            <span
              class="px-2 py-0.5 rounded text-xs font-semibold border"
              style={statusStyles[edu.status]}
            >
              {statusLabels[edu.status]}
            </span>
          </div>

          <h3 class="text-base font-bold mb-1 leading-snug" style="color: var(--text);">
            {t(lang, edu.titleKey as any)}
          </h3>

          <p class="text-sm font-medium mb-1" style="color: var(--accent);">
            {t(lang, edu.schoolKey as any)}
          </p>

          <div class="flex items-center gap-2 mb-3 text-xs" style="color: var(--text-secondary);">
            <span>{t(lang, edu.periodKey as any)}</span>
            <span>·</span>
            <span>{t(lang, edu.locationKey as any)}</span>
          </div>

          <p class="text-sm leading-relaxed flex-1" style="color: var(--text-secondary);">
            {t(lang, edu.descriptionKey as any)}
          </p>

          {edu.noteKey && (
            <p class="mt-3 text-xs italic" style="color: var(--text-secondary);">
              {t(lang, edu.noteKey as any)}
            </p>
          )}
        </div>
      ))}
    </div>

    <!-- Upcoming certifications -->
    <div>
      <h3 class="text-lg font-bold mb-4" style="color: var(--text);">
        Upcoming Certifications
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {upcomingCerts.map((cert) => (
          <div
            class="flex items-center gap-3 px-4 py-3 rounded-lg"
            style="background-color: var(--bg-secondary); border: 1px solid var(--border);"
          >
            <span class="font-bold font-mono text-sm shrink-0" style="color: var(--accent);">
              {cert.name}
            </span>
            <span class="text-sm min-w-0 flex-1" style="color: var(--text-secondary);">
              {cert.full}
            </span>
            <span
              class="px-2 py-0.5 rounded text-xs font-semibold shrink-0"
              style="background-color: rgba(163,113,247,0.1); color: #a371f7; border: 1px solid rgba(163,113,247,0.3);"
            >
              Planned
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
