---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import { education } from '../../data/education';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const statusStyles: Record<string, string> = {
  completed: 'background-color: rgba(63,185,80,0.12); color: #3fb950; border-color: rgba(63,185,80,0.35);',
  pending: 'background-color: rgba(251,191,36,0.12); color: #f59e0b; border-color: rgba(251,191,36,0.35);',
  'in-progress': 'background-color: rgba(88,166,255,0.12); color: var(--accent); border-color: rgba(88,166,255,0.35);',
};

const statusLabels: Record<string, string> = {
  completed: 'Completed',
  pending: 'Exam Pending',
  'in-progress': 'In Progress',
};

---

<section id="education" class="py-24" style="background-color: var(--bg);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'education_title')} />
    </div>

    <!-- Education cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {education.map((edu, index) => (
        <div
          class={`edu-card relative p-5 rounded-xl flex flex-col card-hover reveal ${edu.noteKey ? 'swat-card' : ''}`}
          style={`background-color: var(--card-bg); border: 1px solid var(--card-border); transition-delay: ${index * 0.08}s; box-shadow: var(--shadow-sm);`}
        >
          <!-- Icon + status -->
          <div class="flex items-start justify-between mb-4">
            <div
              class="w-11 h-11 rounded-xl flex items-center justify-center text-xl"
              style="background-color: rgba(var(--accent-rgb), 0.1); border: 1px solid rgba(var(--accent-rgb), 0.2);"
            >
              {edu.type === 'degree' ? '🎓' : '📜'}
            </div>
            <!-- Status badge -->
            <span
              class="px-2.5 py-1 rounded-md text-xs font-semibold border"
              style={statusStyles[edu.status]}
            >
              {statusLabels[edu.status]}
            </span>
          </div>

          <h3 class="text-base font-bold mb-1 leading-snug" style="color: var(--text);">
            {t(lang, edu.titleKey as any)}
          </h3>

          <p class="text-sm font-medium mb-1" style="color: var(--accent);">
            {t(lang, edu.schoolKey as any)}
          </p>

          <div class="flex items-center gap-2 mb-3 text-xs" style="color: var(--text-secondary);">
            <span>{t(lang, edu.periodKey as any)}</span>
            <span>·</span>
            <span>{t(lang, edu.locationKey as any)}</span>
          </div>

          <p class="text-sm leading-relaxed flex-1 whitespace-pre-line" style="color: var(--text-secondary);">
            {t(lang, edu.descriptionKey as any)}
          </p>

          {edu.noteKey && (
            <p class="mt-3 text-xs italic px-3 py-2 rounded-md" style="color: var(--accent); background-color: rgba(var(--accent-rgb), 0.06); border: 1px solid rgba(var(--accent-rgb), 0.15);">
              {t(lang, edu.noteKey as any)}
            </p>
          )}
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .swat-card {
    border-color: rgba(var(--accent-rgb), 0.3) !important;
  }
</style>

<script is:inline>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    var els = document.querySelectorAll('#education .reveal');
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    els.forEach(function (el) { io.observe(el); });
  })();
</script>
