---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import { education } from '../../data/education';
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const statusStyles: Record<string, string> = {
  completed: 'background-color: rgba(63,185,80,0.12); color: #3fb950; border-color: rgba(63,185,80,0.35);',
  pending: 'background-color: rgba(251,191,36,0.12); color: #f59e0b; border-color: rgba(251,191,36,0.35);',
  'in-progress': 'background-color: rgba(88,166,255,0.12); color: var(--accent); border-color: rgba(88,166,255,0.35);',
};

const statusLabels: Record<string, string> = {
  completed: 'Completed',
  pending: 'Exam Pending',
  'in-progress': 'In Progress',
};

// SVG icons per education id — inline, stroke-based, 24px
const eduIcons: Record<string, string> = {
  // Military lyceum → shield
  lyceum: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L3 7v5c0 5.25 3.75 10.15 9 11.35C17.25 22.15 21 17.25 21 12V7L12 2z"/></svg>`,
  // University degrees → graduation cap
  law: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/><path d="M6 12v5c0 1.657 2.686 3 6 3s6-1.343 6-3v-5"/></svg>`,
  econ: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5-10-5z"/><path d="M6 12v5c0 1.657 2.686 3 6 3s6-1.343 6-3v-5"/></svg>`,
  // Professional certificate → award/ribbon
  cert: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M8.56 14.89L7 22l5-3 5 3-1.56-7.11"/></svg>`,
  // Language certificate → globe
  'portuguese-a2': `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  // Online school → monitor/screen
  'onchain-school': `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
};

---

<section id="education" class="py-24" style="background-color: transparent;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'education_title')} />
    </div>

    <!-- Education cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12 stagger-children">
      {education.map((edu, index) => (
        <div
          class={`edu-card relative p-5 rounded-xl flex flex-col card-hover ${edu.noteKey ? 'swat-card' : ''}`}
          style={`background-color: var(--card-bg); border: 1px solid var(--card-border); box-shadow: var(--shadow-sm);`}
        >
          <!-- Icon + status -->
          <div class="flex items-start justify-between mb-4">
            <div
              class="w-11 h-11 rounded-xl flex items-center justify-center text-xl"
              style="background-color: rgba(var(--accent-rgb), 0.1); border: 1px solid rgba(var(--accent-rgb), 0.2);"
            >
              {edu.type === 'degree' ? '🎓' : '📜'}
            </div>
            <!-- Status badge -->
            <span
              class="px-2.5 py-1 rounded-md text-xs font-semibold border"
              style={statusStyles[edu.status]}
            >
              {statusLabels[edu.status]}
            </span>
          </div>

          <h3 class="text-base font-bold mb-1 leading-snug" style="color: var(--text);">
            {t(lang, edu.titleKey as any)}
          </h3>

          <p class="text-sm font-medium mb-1" style="color: var(--accent);">
            {t(lang, edu.schoolKey as any)}
          </p>

          <div class="flex items-center gap-2 mb-3 text-xs" style="color: var(--text-secondary);">
            <span>{t(lang, edu.periodKey as any)}</span>
            <span>·</span>
            <span>{t(lang, edu.locationKey as any)}</span>
          </div>

          <p class="text-sm leading-relaxed flex-1 whitespace-pre-line" style="color: var(--text-secondary);">
            {t(lang, edu.descriptionKey as any)}
          </p>

          {edu.noteKey && (
            <p class="mt-3 text-xs italic px-3 py-2 rounded-md" style="color: var(--accent); background-color: rgba(var(--accent-rgb), 0.06); border: 1px solid rgba(var(--accent-rgb), 0.15);">
              {t(lang, edu.noteKey as any)}
            </p>
          )}
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .swat-card {
    border-color: rgba(var(--accent-rgb), 0.3) !important;
  }
</style>

<script is:inline>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    /* Section title */
    var els = document.querySelectorAll('#education .reveal');
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    els.forEach(function (el) { io.observe(el); });

    /* Stagger education cards */
    var grid = document.querySelector('#education .stagger-children');
    if (grid) {
      var staggerIo = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            staggerIo.unobserve(e.target);
          }
        });
      }, { threshold: 0.08 });
      staggerIo.observe(grid);
    }
  })();
</script>
