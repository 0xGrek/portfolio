---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import { experience } from '../../data/experience';
import SectionTitle from '../ui/SectionTitle.astro';
import TechTag from '../ui/TechTag.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section id="experience" class="py-24" style="background-color: var(--bg-secondary);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'experience_title')} />
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical gradient line with animated draw -->
      <div
        class="timeline-line timeline-line-animated absolute left-4 sm:left-6 top-0 bottom-0 w-px"
        style="background: linear-gradient(to bottom, var(--accent) 0%, rgba(var(--accent-rgb), 0.3) 60%, transparent 100%);"
      ></div>

      <div class="space-y-10">
        {experience.map((exp, index) => (
          <div class={`relative pl-12 sm:pl-16 ${index % 2 === 0 ? 'reveal-left' : 'reveal-right'}`} style={`transition-delay: ${index * 0.1}s;`}>
            <!-- Timeline dot with pulse -->
            <div
              class="timeline-dot timeline-dot-pulse absolute left-1.5 sm:left-3.5 top-1.5 w-5 h-5 rounded-full border-2 flex items-center justify-center cursor-pointer"
              style="background-color: var(--bg-secondary); border-color: var(--accent);"
            >
              <div class="w-2 h-2 rounded-full" style="background-color: var(--accent);"></div>
            </div>

            <!-- Card -->
            <div
              class="exp-card p-5 sm:p-6 rounded-xl card-hover"
              style="background-color: var(--card-bg); border: 1px solid var(--card-border);"
            >
              <!-- Header row -->
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                <div>
                  <h3 class="text-lg font-bold" style="color: var(--text);">
                    {t(lang, exp.titleKey as any)}
                  </h3>
                  <p class="text-sm font-medium" style="color: var(--accent);">
                    {t(lang, exp.companyKey as any)}
                  </p>
                </div>
                <div class="text-right shrink-0">
                  <!-- Period badge -->
                  <span
                    class="inline-block px-2.5 py-1 rounded-md text-xs font-mono font-medium"
                    style="background-color: rgba(var(--accent-rgb), 0.1); color: var(--accent); border: 1px solid rgba(var(--accent-rgb), 0.2);"
                  >
                    {t(lang, exp.periodKey as any)}
                  </span>
                  <p class="text-xs mt-1" style="color: var(--text-secondary);">
                    {t(lang, exp.locationKey as any)}
                  </p>
                </div>
              </div>

              <!-- Description -->
              <p class="text-sm leading-relaxed mb-4" style="color: var(--text-secondary);">
                {t(lang, exp.descriptionKey as any)}
              </p>

              <!-- Bullet points -->
              {exp.bullets.length > 0 && (
                <ul class="space-y-1.5 mb-4">
                  {exp.bullets.map((bulletKey) => {
                    const text = t(lang, bulletKey as any);
                    return text ? (
                      <li class="flex items-start gap-2 text-sm" style="color: var(--text-secondary);">
                        <span class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0" style="background-color: var(--accent);"></span>
                        {text}
                      </li>
                    ) : null;
                  })}
                </ul>
              )}

              <!-- Career progression highlights (e.g. police) -->
              {exp.highlightsKey && (() => {
                const highlights = t(lang, exp.highlightsKey as any);
                return highlights ? (
                  <div
                    class="mb-4 px-3 py-2 rounded-lg text-xs font-mono"
                    style="background-color: rgba(var(--accent-rgb), 0.07); border: 1px solid rgba(var(--accent-rgb), 0.15); color: var(--text-secondary);"
                  >
                    {highlights}
                  </div>
                ) : null;
              })()}

              <!-- Tech tags -->
              <div class="flex flex-wrap gap-2 pt-2 border-t" style="border-color: var(--border);">
                {exp.tags.map((tag) => (
                  <TechTag label={tag} />
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes timeline-pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.5; }
  }
  .timeline-line {
    animation: timeline-pulse 4s ease-in-out infinite;
  }
  .exp-card {
    box-shadow: var(--shadow-sm);
  }
</style>

<script is:inline>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    var els = document.querySelectorAll('#experience .reveal, #experience .reveal-left, #experience .reveal-right, #experience .timeline-line-animated');
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.06 });
    els.forEach(function (el) { io.observe(el); });
  })();
</script>
