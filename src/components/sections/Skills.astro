---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import { skillCategories } from '../../data/skills';
import SectionTitle from '../ui/SectionTitle.astro';
import TechTag from '../ui/TechTag.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Category icons
const categoryIcons: Record<string, string> = {
  skills_blockchain: '⛓',
  skills_analytics: '📊',
  skills_compliance: '🛡',
  skills_automation: '⚙️',
  skills_ai: '🤖',
  skills_dev: '💻',
};
---

<section id="skills" class="py-24" style="background-color: var(--bg-secondary);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'skills_title')} />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {skillCategories.map((category, index) => (
        <div
          class="skill-card p-5 rounded-xl card-hover reveal"
          style={`background-color: var(--card-bg); border: 1px solid var(--card-border); transition-delay: ${index * 0.06}s; box-shadow: var(--shadow-sm);`}
        >
          <h3 class="flex items-center gap-2 text-sm font-bold uppercase tracking-wider mb-4" style="color: var(--accent);">
            <span class="text-base" aria-hidden="true">
              {categoryIcons[category.titleKey] || '▸'}
            </span>
            {t(lang, category.titleKey as any)}
          </h3>
          <div class="flex flex-wrap gap-2">
            {category.skills.map((skill) => (
              <TechTag label={skill} />
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    var els = document.querySelectorAll('#skills .reveal');
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    els.forEach(function (el) { io.observe(el); });
  })();
</script>
