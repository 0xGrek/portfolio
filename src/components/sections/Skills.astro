---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import { skillCategories } from '../../data/skills';
import SectionTitle from '../ui/SectionTitle.astro';
import TechTag from '../ui/TechTag.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Category icons — inline SVG, stroke="currentColor", no fill, 20px
const categoryIcons: Record<string, string> = {
  skills_tech_core: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  skills_blockchain: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 20.5 7 20.5 17 12 22 3.5 17 3.5 7"/><line x1="12" y1="2" x2="12" y2="22"/><line x1="3.5" y1="7" x2="20.5" y2="17"/><line x1="20.5" y1="7" x2="3.5" y2="17"/></svg>`,
  skills_security: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  skills_automation: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  skills_languages: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
};
---

<section id="skills" class="py-24" style="background-color: transparent;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'skills_title')} />
    </div>

    <div class="flex flex-col gap-6 stagger-children">
      {skillCategories.map((category, index) => (
        <div
          class="skill-card p-6 rounded-xl card-hover"
          style={`background-color: var(--card-bg); border: 1px solid var(--card-border);`}
        >
          <!-- Category header -->
          <h3 class="flex items-center gap-2 text-sm font-bold uppercase tracking-wider mb-5" style="color: var(--accent);">
            <span class="flex items-center" set:html={categoryIcons[category.titleKey] || '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>'} />
            {t(lang, category.titleKey as any)}
          </h3>

          <!-- Sub-groups -->
          <div class="flex flex-col gap-4">
            {category.subGroups.map((group) => (
              <div class="skill-subgroup">
                {/* Languages category has a single flat group with no label */}
                {group.nameKey ? (
                  <div class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-4">
                    <div class="sm:w-48 lg:w-56 shrink-0">
                      <span class="text-xs font-semibold uppercase tracking-wide" style="color: var(--text-secondary);">
                        {t(lang, group.nameKey as any)}
                      </span>
                    </div>
                    <div class="flex flex-wrap gap-2 flex-1">
                      {group.skills.map((skill) => (
                        <TechTag label={skill} />
                      ))}
                    </div>
                  </div>
                ) : (
                  <div class="flex flex-wrap gap-2">
                    {group.skills.map((skill) => (
                      <TechTag label={skill} />
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Scroll-reveal handled by global IntersectionObserver in BaseLayout.astro -->

<style>
  /* Non-interactive display card — override card-hover cursor */
  .skill-card {
    cursor: default;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
</style>
