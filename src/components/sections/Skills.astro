---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import { skillCategories } from '../../data/skills';
import SectionTitle from '../ui/SectionTitle.astro';
import TechTag from '../ui/TechTag.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Category icons
const categoryIcons: Record<string, string> = {
  skills_tech_core: '💻',
  skills_blockchain: '⛓️',
  skills_security: '🛡️',
  skills_automation: '⚡',
  skills_languages: '🌐',
};
---

<section id="skills" class="py-24" style="background-color: var(--bg-secondary);">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle title={t(lang, 'skills_title')} />
    </div>

    <div class="flex flex-col gap-6 stagger-children">
      {skillCategories.map((category, index) => (
        <div
          class="skill-card p-6 rounded-xl card-hover"
          style={`background-color: var(--card-bg); border: 1px solid var(--card-border);`}
        >
          <!-- Category header -->
          <h3 class="flex items-center gap-2 text-sm font-bold uppercase tracking-wider mb-5" style="color: var(--accent);">
            <span class="text-base" aria-hidden="true">
              {categoryIcons[category.titleKey] || '▸'}
            </span>
            {t(lang, category.titleKey as any)}
          </h3>

          <!-- Sub-groups -->
          <div class="flex flex-col gap-4">
            {category.subGroups.map((group) => (
              <div class="skill-subgroup">
                {/* Languages category has a single flat group with no label */}
                {group.nameKey ? (
                  <div class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-4">
                    <div class="sm:w-48 lg:w-56 shrink-0">
                      <span class="text-xs font-semibold uppercase tracking-wide" style="color: var(--text-secondary);">
                        {t(lang, group.nameKey as any)}
                      </span>
                    </div>
                    <div class="flex flex-wrap gap-2 flex-1">
                      {group.skills.map((skill) => (
                        <TechTag label={skill} />
                      ))}
                    </div>
                  </div>
                ) : (
                  <div class="flex flex-wrap gap-2">
                    {group.skills.map((skill) => (
                      <TechTag label={skill} />
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    if (!('IntersectionObserver' in window)) return;
    /* Section title */
    var els = document.querySelectorAll('#skills .reveal');
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    els.forEach(function (el) { io.observe(el); });

    /* Stagger skill cards */
    var container = document.querySelector('#skills .stagger-children');
    if (container) {
      var staggerIo = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            staggerIo.unobserve(e.target);
          }
        });
      }, { threshold: 0.08 });
      staggerIo.observe(container);
    }
  })();
</script>
