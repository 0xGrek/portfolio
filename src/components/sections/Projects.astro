---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';
import { projects } from '../../data/projects';
import SectionTitle from '../ui/SectionTitle.astro';
import TechTag from '../ui/TechTag.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const categoryColors: Record<string, string> = {
  web: '#58a6ff',
  crypto: '#f7931a',
  ai: '#a371f7',
  analytics: '#3fb950',
  trading: '#ffa657',
};

// SVG icon paths per category — subtle, monochrome background placeholders
const categoryIcons: Record<string, string> = {
  // Globe / web
  web: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" width="64" height="64"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  // Hexagon / blockchain
  crypto: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" width="64" height="64"><polygon points="12 2 22 7 22 17 12 22 2 17 2 7"/><line x1="12" y1="2" x2="12" y2="22"/><line x1="2" y1="7" x2="22" y2="7"/><line x1="2" y1="17" x2="22" y2="17"/></svg>`,
  // CPU chip / AI
  ai: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" width="64" height="64"><rect x="7" y="7" width="10" height="10" rx="1"/><path d="M16 3v4M8 3v4M16 17v4M8 17v4M3 8h4M17 8h4M3 16h4M17 16h4"/></svg>`,
  // Bar chart / analytics
  analytics: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" width="64" height="64"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>`,
  // Trending up / trading
  trading: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" width="64" height="64"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
};
---

<section id="projects" class="py-24" style="background-color: transparent;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionTitle
        title={t(lang, 'projects_title')}
        subtitle={t(lang, 'projects_subtitle')}
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children" id="projects-grid">
      {projects.map((project, index) => (
        <article
          class={`project-card relative flex flex-col rounded-xl overflow-hidden${project.featured ? ' project-featured' : ''}${index >= 3 ? ' project-extra' : ''}`}
          style={`background-color: var(--card-bg); border: 1px solid var(--card-border);`}
          id={`card-${project.id}`}
          data-project-index={index}
        >
          <!-- Header area — clickable to toggle expand -->
          <button
            class="project-toggle w-full text-left"
            data-project-id={project.id}
            aria-expanded="false"
            aria-controls={`expand-${project.id}`}
            style="background: none; border: none; padding: 0; cursor: pointer; display: block; width: 100%;"
          >
            <div
              class="relative h-40 flex items-center justify-center overflow-hidden group"
              style="background: linear-gradient(135deg, var(--bg-secondary), var(--bg)); border-bottom: 1px solid var(--border);"
            >
              <!-- Category dot -->
              <div
                class="absolute top-3 left-3 w-2.5 h-2.5 rounded-full"
                style={`background-color: ${categoryColors[project.category] || 'var(--accent)'};`}
              ></div>

              <!-- Featured badge — top-right -->
              {project.featured && (
                <span
                  class="absolute top-3 right-3 px-2.5 py-1 rounded-md text-xs font-bold tracking-wide"
                  style="background-color: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(var(--accent-rgb), 0.4);"
                >
                  ★ Featured
                </span>
              )}

              <!-- Project category icon -->
              <span class="select-none" style="color: var(--text); opacity: 0.12;" set:html={categoryIcons[project.category] || categoryIcons.web} />

              <!-- "View Details" hover overlay -->
              <div
                class="expand-hint absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-200"
                style="background-color: rgba(var(--accent-rgb), 0.08);"
              >
                <span class="text-sm font-semibold px-4 py-1.5 rounded-full expand-label" style="color: var(--accent); border: 1px solid var(--accent);">
                  {t(lang, 'project_view')}
                </span>
              </div>
            </div>
          </button>

          <!-- Card summary (always visible) -->
          <div class="flex flex-col flex-1 p-5">
            <!-- Title row — clickable -->
            <button
              class="project-toggle w-full text-left mb-2"
              data-project-id={project.id}
              aria-expanded="false"
              aria-controls={`expand-${project.id}`}
              style="background: none; border: none; padding: 0; cursor: pointer;"
            >
              <div class="flex items-center justify-between gap-2">
                <h3 class="text-base font-bold leading-snug" style="color: var(--text);">
                  {t(lang, project.titleKey as any)}
                </h3>
                <svg class="project-arrow flex-shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="color: rgba(var(--accent-rgb), 0.7);"><path d="M3 5.5L8 10.5L13 5.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </button>

            <p class="text-sm leading-relaxed mb-4 flex-1" style="color: var(--text-secondary);">
              {t(lang, project.descriptionKey as any)}
            </p>

            <!-- Compact view: metric + tech — hidden when expanded -->
            <div class="card-compact-footer">
              <!-- Key metric (first only) -->
              {project.metrics && project.metrics[0] && (
                <div class="mb-3">
                  <span
                    class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-semibold"
                    style="background-color: rgba(var(--accent-rgb), 0.1); color: var(--accent); border: 1px solid rgba(var(--accent-rgb), 0.2);"
                  >
                    <strong>{project.metrics[0].value}</strong>
                    {project.metrics[0].label && (
                      <span style="font-weight: 400; opacity: 0.75;">{project.metrics[0].label}</span>
                    )}
                  </span>
                </div>
              )}

              <!-- Tech tags (max 3) -->
              <div class="flex flex-wrap gap-1.5 pt-3 border-t" style="border-color: var(--border);">
                {project.tech.slice(0, 3).map((tech) => (
                  <TechTag label={tech} />
                ))}
                {project.tech.length > 3 && (
                  <span class="text-xs px-2 py-0.5 rounded" style="color: var(--text-secondary); background-color: var(--bg-secondary);">
                    +{project.tech.length - 3}
                  </span>
                )}
              </div>
            </div>
          </div>

          <!-- ── Inline expand panel ───────────────────────────────── -->
          <div
            class="project-expand"
            id={`expand-${project.id}`}
          >
            <div class="expand-inner">
            <div class="px-5 pb-5 pt-4" style="border-top: 1px solid var(--border);">

              <!-- Long description -->
              <p class="text-sm leading-relaxed mb-5" style="color: var(--text-secondary);">
                {t(lang, project.longDescriptionKey as any)}
              </p>

              <!-- Full tech stack — только если tech > 3, иначе уже показано в карточке -->
              {project.tech.length > 3 && (
                <div class="mb-5">
                  <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: var(--text-secondary); opacity: 0.6;">
                    Tech Stack
                  </p>
                  <div class="flex flex-wrap gap-1.5">
                    {project.tech.map((tech) => (
                      <TechTag label={tech} />
                    ))}
                  </div>
                </div>
              )}

              <!-- All metrics — только если больше 1 (первый уже в карточке) -->
              {project.metrics && project.metrics.length > 1 && (
                <div class="mb-5">
                  <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: var(--text-secondary); opacity: 0.6;">
                    Key Metrics
                  </p>
                  <div class="flex flex-wrap gap-2">
                    {project.metrics.map((m) => (
                      <span
                        class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold"
                        style="background-color: rgba(var(--accent-rgb), 0.1); color: var(--accent); border: 1px solid rgba(var(--accent-rgb), 0.25);"
                      >
                        <strong>{m.value}</strong>
                        {m.label && <span style="opacity: 0.7; font-weight: 400;">{m.label}</span>}
                      </span>
                    ))}
                  </div>
                </div>
              )}

              <!-- Links -->
              <div class="flex flex-wrap gap-2 mt-1">
                {project.links.live && (
                  <a
                    href={project.links.live}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-link-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-semibold transition-all duration-200"
                    style="background-color: var(--accent); color: #fff;"
                    onclick="event.stopPropagation()"
                  >
                    {lang === 'ua' ? 'Відвідати сайт' : lang === 'pt' ? 'Visitar site' : lang === 'es' ? 'Visitar sitio' : 'Visit Site'}
                    <span aria-hidden="true">→</span>
                  </a>
                )}
                {project.links.demo && (
                  <a
                    href={project.links.demo}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-link-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-semibold transition-all duration-200"
                    style="background-color: rgba(var(--accent-rgb), 0.12); color: var(--accent); border: 1px solid rgba(var(--accent-rgb), 0.3);"
                    onclick="event.stopPropagation()"
                  >
                    Demo
                    <span aria-hidden="true">↗</span>
                  </a>
                )}
                {project.links.github && (
                  <a
                    href={project.links.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-link-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-semibold transition-all duration-200"
                    style="background-color: rgba(var(--accent-rgb), 0.08); color: var(--text-secondary); border: 1px solid var(--border);"
                    onclick="event.stopPropagation()"
                  >
                    GitHub
                    <span aria-hidden="true">↗</span>
                  </a>
                )}

                <!-- Close / collapse button -->
                <button
                  class="project-toggle ml-auto inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-xs font-medium transition-all duration-200"
                  data-project-id={project.id}
                  style="background-color: var(--bg-secondary); color: var(--text-secondary); border: 1px solid var(--border); cursor: pointer;"
                  aria-expanded="true"
                  aria-controls={`expand-${project.id}`}
                >
                  {lang === 'ua' ? 'Згорнути' : lang === 'pt' ? 'Recolher' : lang === 'es' ? 'Colapsar' : 'Collapse'} ▲
                </button>
              </div>
            </div>
            </div>
          </div>

        </article>
      ))}

      <!-- Private Projects card — static, non-clickable -->
      <article
        class="private-card relative flex flex-col rounded-xl overflow-hidden"
        style="border: 1.5px dashed var(--card-border); background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--bg) 100%);"
      >
        <!-- Top visual area -->
        <div
          class="relative h-40 flex items-center justify-center overflow-hidden"
          style="background: linear-gradient(135deg, var(--bg) 0%, var(--bg-secondary) 100%); border-bottom: 1px dashed var(--card-border);"
        >
          <!-- Lock icon -->
          <span class="absolute top-3 right-3 text-lg" aria-hidden="true" style="opacity: 0.45;">🔒</span>

          <!-- Big muted text -->
          <span class="text-5xl font-bold font-mono select-none" style="color: var(--text); opacity: 0.07;">NDA</span>
        </div>

        <!-- Card body -->
        <div class="flex flex-col flex-1 p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-lg" aria-hidden="true">🔒</span>
            <h3 class="text-base font-bold leading-snug" style="color: var(--text);">
              {t(lang, 'proj_private_title' as any)}
            </h3>
          </div>

          <p class="text-sm leading-relaxed flex-1" style="color: var(--text-secondary);">
            {t(lang, 'proj_private_desc' as any)}
          </p>

          <!-- Bottom hint -->
          <div class="mt-4 pt-3" style="border-top: 1px dashed var(--border);">
            <span
              class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1 rounded-full"
              style="background-color: rgba(var(--accent-rgb), 0.07); color: var(--text-secondary); border: 1px dashed rgba(var(--accent-rgb), 0.25);"
            >
              <span aria-hidden="true">🔐</span>
              Under NDA
            </span>
          </div>
        </div>
      </article>

    </div>

    <!-- Pagination button — only shown if there are more than 3 projects -->
    {projects.length > 3 && (
      <div class="flex justify-center mt-8">
        <button
          id="projects-toggle-btn"
          class="projects-show-more-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium transition-all duration-200"
          aria-expanded="false"
          aria-controls="projects-grid"
        >
          <span class="btn-label">{lang === 'ua' ? 'Показати ще' : lang === 'pt' ? 'Mostrar mais' : lang === 'es' ? 'Mostrar más' : 'Show more'}</span>
          <svg class="btn-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M3 5.5L8 10.5L13 5.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    )}

  </div>
</section>

<style>
  /* Featured projects get an accent border glow */
  .project-featured {
    border-color: rgba(var(--accent-rgb), 0.3) !important;
    box-shadow: var(--shadow-sm), 0 0 0 1px rgba(var(--accent-rgb), 0.12);
  }

  /* Card hover: show hint overlay, lift slightly */
  .project-card:not(.expanded):hover .expand-hint {
    opacity: 1;
  }
  .project-card {
    transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  .project-card:not(.expanded):hover {
    transform: translateY(-3px);
    border-color: rgba(var(--accent-rgb), 0.4) !important;
    box-shadow: var(--shadow-md) !important;
  }

  /* When expanded — no hover lift, accent border */
  .project-card.expanded {
    border-color: rgba(var(--accent-rgb), 0.45) !important;
    box-shadow: var(--shadow-md), 0 0 20px rgba(var(--accent-rgb), 0.1) !important;
  }
  .project-featured.expanded {
    border-color: rgba(var(--accent-rgb), 0.65) !important;
  }

  /* Chevron rotation when expanded */
  .project-arrow { transition: transform 0.3s ease; }
  .project-card.expanded .project-arrow { transform: rotate(180deg); }

  /* Hide view-details hint when expanded */
  .project-card.expanded .expand-hint {
    display: none;
  }

  /* Keyboard focus ring */
  .project-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 0.5rem;
  }

  /* Link buttons hover */
  .project-link-btn:hover {
    opacity: 0.82;
    transform: translateY(-1px);
  }

  /*
   * ── Expand panel — CSS grid-template-rows approach ──────────
   * grid: 0fr → 1fr даёт плавное раскрытие без "прыжка"
   * который возникает при max-height: 0 → большое число
   */
  .project-expand {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .project-expand .expand-inner {
    overflow: hidden;
  }
  .project-card.expanded .project-expand {
    grid-template-rows: 1fr;
  }

  /*
   * Compact footer (metric + first 3 tags) скрывается при expand
   * чтобы не дублировать данные которые уже видны в панели
   */
  .card-compact-footer {
    transition: opacity 0.2s ease;
  }
  .project-card.expanded .card-compact-footer {
    display: none;
  }

  /* Screenshots scroll on mobile */
  @media (max-width: 640px) {
    .project-expand video {
      max-height: 200px;
    }
  }

  /* Private Projects card */
  .private-card {
    transition: box-shadow 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    cursor: default;
  }
  .private-card:hover {
    transform: translateY(-2px);
    border-color: rgba(var(--accent-rgb), 0.3) !important;
    box-shadow: var(--shadow-sm);
  }

</style>

<script is:inline>
  (function () {
    /* ── Scroll-reveal ─────────────────────────────────── */
    if ('IntersectionObserver' in window) {
      /* Section title reveal */
      var titleEls = document.querySelectorAll('#projects .reveal');
      var titleIo = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            titleIo.unobserve(e.target);
          }
        });
      }, { threshold: 0.1 });
      titleEls.forEach(function (el) { titleIo.observe(el); });

      /* Stagger cards grid */
      var grid = document.querySelector('#projects .stagger-children');
      if (grid) {
        var gridIo = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              gridIo.unobserve(e.target);
            }
          });
        }, { threshold: 0.06 });
        gridIo.observe(grid);
      }
    }

    /*
     * ── Accordion expand logic ──────────────────────────
     * Анимация теперь полностью в CSS (grid-template-rows transition).
     * JS только переключает класс 'expanded' и обновляет aria-атрибуты.
     * Это чище: нет манипуляций с maxHeight, нет reflow хаков.
     */
    function expandCard(card) {
      card.classList.add('expanded');
      card.querySelectorAll('.project-toggle').forEach(function (btn) {
        btn.setAttribute('aria-expanded', 'true');
      });
    }

    function collapseCard(card) {
      card.classList.remove('expanded');
      card.querySelectorAll('.project-toggle').forEach(function (btn) {
        btn.setAttribute('aria-expanded', 'false');
      });
    }

    function toggleProject(projectId) {
      var card = document.getElementById('card-' + projectId);
      if (!card) return;

      var isExpanded = card.classList.contains('expanded');
      if (isExpanded) {
        collapseCard(card);
      } else {
        expandCard(card);
        // Scroll into view on mobile after transition starts
        setTimeout(function () {
          card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, 100);
      }
    }

    // Attach click handlers to all toggle buttons
    document.querySelectorAll('.project-toggle').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        var id = btn.getAttribute('data-project-id');
        if (id) toggleProject(id);
      });
      btn.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          var id = btn.getAttribute('data-project-id');
          if (id) toggleProject(id);
        }
      });
    });

    // Prevent link clicks from bubbling and triggering toggle
    document.querySelectorAll('.project-link-btn').forEach(function (link) {
      link.addEventListener('click', function (e) {
        e.stopPropagation();
      });
    });
  })();
</script>
