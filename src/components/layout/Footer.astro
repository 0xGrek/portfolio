---
import { t } from '../../i18n/index';
import type { Lang } from '../../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer id="footer" class="border-t" style="border-color: var(--border); background-color: var(--bg-secondary); position: relative; z-index: 1;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Top row: social icons + back to top -->
    <div class="flex items-center justify-between mb-6">
      <!-- Social links -->
      <div class="flex items-center gap-5">
        {socials.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.name}
            class={`magnetic social-hover social-hover--${social.name.toLowerCase().replace(/[^a-z]/g, '')}`}
            style="color: var(--text-secondary); display: inline-flex;"
          >
            <Fragment set:html={social.icon} />
          </a>
        ))}
      </div>

      <!-- Back to top -->
      <button
        id="back-to-top"
        aria-label="Back to top"
        class="back-to-top-btn flex items-center gap-1.5 text-xs font-medium px-3 py-2 rounded-lg border transition-all hover:opacity-80"
        style="color: var(--text-secondary); border-color: var(--border); background-color: var(--card-bg);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
        Top
      </button>
    </div>

    <!-- Badge + location + copyright -->
    <div class="text-center space-y-2 border-t pt-5" style="border-color: var(--border);">
      <div class="flex items-center justify-center gap-3 flex-wrap">
        <span class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full border" style="color: var(--accent); border-color: var(--accent); background-color: color-mix(in srgb, var(--accent) 10%, transparent);">
          <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
          Open to opportunities
        </span>
        <span class="text-xs" style="color: var(--text-secondary); opacity: 0.7;">
          Lisbon, Portugal
        </span>
      </div>
      <p class="text-xs" style="color: var(--text-secondary); opacity: 0.6;">
        {t(lang, 'footer_rights')}
      </p>
      <p class="text-xs mt-2 max-w-2xl mx-auto" style="color: var(--text-secondary); opacity: 0.45; font-size: 0.7rem; line-height: 1.5;">
        {t(lang, 'footer_compliance')}
      </p>
    </div>
  </div>
</footer>

<style>
  .back-to-top-btn {
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s ease;
  }
  .back-to-top-btn:hover {
    color: var(--accent) !important;
    border-color: var(--accent) !important;
    transform: translateY(-3px);
    box-shadow: 0 4px 12px rgba(var(--accent-rgb), 0.2);
  }
  .back-to-top-btn:active {
    transform: translateY(-1px);
  }

  /* Platform-specific social hover colors */
  .social-hover--github:hover { color: #e6edf3 !important; }
  .social-hover--linkedin:hover { color: #0a66c2 !important; }
  .social-hover--xtwitter:hover { color: #e7e9ea !important; }
  .social-hover--telegram:hover { color: #26a5e4 !important; }
  .social-hover--email:hover { color: var(--accent) !important; }
</style>

<script is:inline>
  var btn = document.getElementById('back-to-top');
  if (btn) {
    btn.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
