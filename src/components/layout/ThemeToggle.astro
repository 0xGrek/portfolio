---
// No props needed — reads from localStorage
---

<button
  id="theme-toggle"
  aria-label="Toggle theme"
  class="theme-toggle-btn p-2 rounded hover:opacity-80 focus:outline-none"
  style="color: var(--text-secondary);"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    var iconSun = document.getElementById('icon-sun');
    var iconMoon = document.getElementById('icon-moon');

    function applyTheme(theme, instant) {
      var isDark = theme === 'dark';
      var html = document.documentElement;

      if (instant) {
        // Block all transitions for one frame so the switch is instant
        html.classList.add('no-transition');
      }

      html.classList.toggle('dark', isDark);
      html.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);

      // Sun = switch to light (shown in dark mode)
      // Moon = switch to dark (shown in light mode)
      iconSun.style.display = isDark ? 'block' : 'none';
      iconMoon.style.display = isDark ? 'none' : 'block';

      if (instant) {
        // Force reflow so no-transition applies, then remove on next frame
        html.offsetHeight; // eslint-disable-line no-unused-expressions
        requestAnimationFrame(function () {
          html.classList.remove('no-transition');
        });
      }
    }

    // Init (no animation on page load)
    var stored = localStorage.getItem('theme') || 'dark';
    applyTheme(stored, false);

    btn.addEventListener('click', function () {
      var current = localStorage.getItem('theme') || 'dark';
      // Spin animation on the button only (not the whole page)
      btn.style.animation = 'none';
      btn.offsetHeight; /* reflow */
      btn.style.animation = 'toggleRotate 0.35s ease forwards';
      // Switch theme instantly (no CSS transitions during switch)
      applyTheme(current === 'dark' ? 'light' : 'dark', true);
    });
  })();
</script>

<style>
  .theme-toggle-btn {
    transition: color 0.2s ease,
                background-color 0.2s ease,
                transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    border-radius: 8px;
  }
  .theme-toggle-btn:hover {
    color: var(--accent) !important;
    background-color: var(--accent-subtle);
    transform: scale(1.1);
  }
  .theme-toggle-btn:active {
    transform: scale(0.95);
  }
</style>
