---
import type { Lang } from '../../i18n/index';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const langs: { code: Lang; label: string }[] = [
  { code: 'ua', label: 'UA' },
  { code: 'en', label: 'EN' },
  { code: 'pt', label: 'PT' },
  { code: 'es', label: 'ES' },
];

// Build target URL: replace current lang segment
function getTargetUrl(targetLang: Lang): string {
  const path = Astro.url.pathname;
  const segments = path.split('/');
  // segments[0] = '', segments[1] = lang, rest = page path
  segments[1] = targetLang;
  return segments.join('/') || `/${targetLang}/`;
}
---

<div class="relative" tabindex="0" style="outline: none;">
  <!-- Trigger button -->
  <button
    class="flex items-center gap-1 px-2 py-1 rounded text-xs font-mono font-medium transition-colors hover:opacity-80 focus:outline-none"
    style="color: var(--text-secondary); background-color: var(--bg-secondary); border: 1px solid var(--border);"
    aria-label="Switch language"
  >
    {lang.toUpperCase()}
    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <!-- Dropdown — visible on :focus-within of parent div -->
  <div
    class="lang-dropdown absolute right-0 top-full mt-1 rounded overflow-hidden shadow-lg z-50"
    style="background-color: var(--card-bg); border: 1px solid var(--card-border); min-width: 70px;"
  >
    {langs.map((l) => (
      <a
        href={getTargetUrl(l.code)}
        class={`block px-3 py-2 text-xs font-mono font-medium transition-colors hover:opacity-80 ${l.code === lang ? 'font-bold' : ''}`}
        style={l.code === lang ? 'color: var(--accent);' : 'color: var(--text-secondary);'}
      >
        {l.label}
      </a>
    ))}
  </div>
</div>

<style>
  div[tabindex="0"] .lang-dropdown {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px) scale(0.97);
    transform-origin: top right;
    transition: opacity 0.2s ease, transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: var(--shadow-md);
  }
  div[tabindex="0"]:focus-within .lang-dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }
  .lang-dropdown a:hover {
    background-color: var(--accent-subtle);
    color: var(--accent) !important;
  }
</style>
