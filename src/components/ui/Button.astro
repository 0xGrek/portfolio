---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  ...rest
} = Astro.props;

const sizeClasses = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3 text-base',
};

const variantStyles = {
  primary: 'background-color: var(--accent); color: #ffffff;',
  secondary: 'background-color: transparent; color: var(--accent); border: 1px solid var(--accent);',
};

const baseClass = `btn inline-flex items-center justify-center font-medium rounded-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 ${sizeClasses[size]} ${className}`;
const style = variantStyles[variant];
const dataVariant = variant;
---

{href ? (
  <a href={href} class={baseClass} style={style} data-variant={dataVariant} {...rest}>
    <slot />
  </a>
) : (
  <button class={baseClass} style={style} data-variant={dataVariant} {...rest}>
    <slot />
  </button>
)}

<style>
  .btn {
    cursor: pointer;
    transition: background-color 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    letter-spacing: 0.01em;
  }

  /* Primary: solid fill, darker on hover + subtle glow */
  .btn[data-variant="primary"] {
    background-color: var(--accent);
  }
  .btn[data-variant="primary"]:hover {
    background-color: var(--accent-hover);
    box-shadow: 0 0 0 4px rgba(var(--accent-rgb), 0.2);
  }
  .btn[data-variant="primary"]:active {
    background-color: var(--accent-hover);
    box-shadow: none;
  }

  /* Secondary: transparent + border, light fill on hover */
  .btn[data-variant="secondary"] {
    background-color: transparent;
  }
  .btn[data-variant="secondary"]:hover {
    background-color: rgba(var(--accent-rgb), 0.1);
  }
  .btn[data-variant="secondary"]:active {
    background-color: rgba(var(--accent-rgb), 0.15);
  }

  .btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 8px;
  }
</style>
