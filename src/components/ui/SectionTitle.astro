---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-12">
  <h2 class="text-3xl sm:text-4xl font-bold mb-2" style="color: var(--text);">
    {title}
  </h2>
  <!-- Accent underline -->
  <div class="h-1 w-12 rounded-full mb-4" style="background-color: var(--accent);"></div>
  {subtitle && (
    <p class="text-base sm:text-lg max-w-2xl" style="color: var(--text-secondary);">
      {subtitle}
    </p>
  )}
</div>
